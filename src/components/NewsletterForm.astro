<form name="newsletter" method="POST" action="/api/newsletter" class="mt-6 grid items-end gap-3 md:grid-cols-[1fr_auto]">
  <input name="_hp" type="text" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;height:0;width:0;" />
  <input name="_t" type="hidden" id="newsletter-t" />
  <script>document.getElementById('newsletter-t').value = Date.now();</script>
  <label class="grid w-full gap-1.5">
    <span class="text-xs font-semibold text-slate-600">Adresse email</span>
    <input
      type="email"
      name="email"
      required
      class="w-full rounded-full border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900"
    />
  </label>
  <button type="submit" class="rounded-full bg-brand-yellow px-6 py-3 text-sm font-semibold text-brand-dark">
    Recevoir les actus
  </button>
</form>
