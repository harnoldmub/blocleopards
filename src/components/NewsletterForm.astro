<form name="newsletter" method="POST" data-netlify="true" class="mt-6 grid gap-3 md:grid-cols-[1fr_auto]">
  <input type="hidden" name="form-name" value="newsletter" />
  <input
    type="email"
    name="email"
    required
    placeholder="Ton email"
    class="w-full rounded-full border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 placeholder:text-slate-400"
  />
  <button type="submit" class="rounded-full bg-brand-yellow px-6 py-3 text-sm font-semibold text-brand-dark">
    Recevoir les actus
  </button>
</form>
