---
const { title, description, image, url } = Astro.props;

const SITE = "https://blocleopards.com";
const ogImage = image ? (image.startsWith("http") ? image : `${SITE}${image}`) : `${SITE}/media/supporters-diaspora-01.jpg`;
const canonical = url ?? Astro.url?.toString() ?? SITE;
---
<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content="index, follow" />
<link rel="canonical" href={canonical} />

<!-- Open Graph -->
<meta property="og:site_name" content="Bloc Léopards" />
<meta property="og:locale" content="fr_FR" />
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="Bloc Léopards — Supporters de la RDC" />

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@blocleopards" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- Structured data — Organization -->
<script type="application/ld+json">
{JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Bloc Léopards",
  "url": "https://blocleopards.com",
  "logo": "https://blocleopards.com/brand/logo.png",
  "sameAs": [
    "https://www.instagram.com/blocleopards",
    "https://www.facebook.com/blocleopards",
    "https://x.com/blocleopards"
  ],
  "description": "Bloc Léopards rassemble les supporters des Léopards de la RDC autour d'une mobilisation positive, informée et respectueuse."
})}
</script>
