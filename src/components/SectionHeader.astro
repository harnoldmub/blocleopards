---
const { title, eyebrow, description } = Astro.props;
---
<div class="mb-8">
  {eyebrow && <p class="text-xs uppercase tracking-[0.3em] text-brand-yellow">{eyebrow}</p>}
  <h2 class="section-title text-4xl md:text-5xl">{title}</h2>
  {description && <p class="mt-2 max-w-2xl text-sm text-slate-600">{description}</p>}
</div>
