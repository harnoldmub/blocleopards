---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Card from "../components/Card.astro";
import kit from "../data/kit.json";
import { getCollection } from "astro:content";

const campaigns = await getCollection("campaigns");
---
<BaseLayout title="Campagnes" description="Campagnes d'influence et hashtags Bloc Leopards.">
  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeader eyebrow="Influence" title="Campagnes officielles" description="DEMO - Campagnes types et hashtags pour mobiliser." />
    <div class="grid gap-6 md:grid-cols-2">
      {campaigns.map((campaign) => (
        <Card
          title={campaign.data.title}
          description={`${campaign.data.description} Hashtag: ${campaign.data.hashtag}`}
          meta={campaign.data.status}
          image={campaign.data.image}
        />
      ))}
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <SectionHeader eyebrow="Slogans" title="Idees de campagnes" description="Propositions de slogans courts pour affiches et reseaux." />
      <div class="grid gap-4 md:grid-cols-2">
        {kit.slogans.map((slogan) => (
          <div class="rounded-2xl border border-slate-200 bg-white p-4 text-sm">{slogan}</div>
        ))}
      </div>
      <div class="mt-10 rounded-3xl border border-slate-200 bg-white p-6 text-sm text-slate-700">
        <p class="text-xs uppercase tracking-[0.3em] text-brand-yellow">{kit.communique.title}</p>
        <p class="mt-3">{kit.communique.body}</p>
      </div>
    </div>
  </section>
</BaseLayout>
