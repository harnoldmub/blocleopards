---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Gallery from "../components/Gallery.astro";
import media from "../data/media.json";
---
<BaseLayout title="Media" description="Galerie photos et videos du Bloc Leopards.">
  <PageHero title="Media" subtitle="L'ambiance du bloc en images" image="/media/supporters-diaspora-03.jpg" />
  <section class="mx-auto grid max-w-6xl gap-8 px-4 py-16 md:grid-cols-[1.2fr_0.8fr]">
    <div>
      <SectionHeader eyebrow="Film" title="Hommage a la diaspora" description="Le match amical a Liege, Marbella et la ferveur des supporters." />
      <div class="mx-auto max-w-sm md:mx-0">
        <video class="aspect-[9/16] w-full rounded-3xl border border-slate-200 bg-slate-950 object-cover shadow-deep" controls poster="/media/hommage-diaspora-cover.jpg">
          <source src="/videos/hommage-diaspora-match-amical.mp4" type="video/mp4" />
        </video>
      </div>
    </div>
    <aside class="flex flex-col justify-center rounded-3xl border border-slate-200 bg-white p-6 shadow-deep">
      <p class="text-xs uppercase tracking-[0.3em] text-brand-yellow">Audio</p>
      <h2 class="section-title mt-3 text-4xl">Voix du bloc</h2>
      <p class="mt-3 text-sm leading-6 text-slate-600">Une version audio est disponible pour relayer l'hommage sur les canaux supporters.</p>
      <audio class="mt-6 w-full" controls src="/audio/hommage-diaspora.mp3"></audio>
      <a href="/actus/2026-05-25-hommage-diaspora" class="mt-6 inline-flex rounded-full bg-brand-yellow px-5 py-3 text-sm font-semibold text-brand-dark">Lire l'article</a>
    </aside>
  </section>
  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeader eyebrow="Photos" title="Galerie diaspora" description="Portraits, drapeaux et moments de tribune." />
    <Gallery items={media} />
  </section>
</BaseLayout>
