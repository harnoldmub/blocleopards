---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Card from "../components/Card.astro";
import NewsletterForm from "../components/NewsletterForm.astro";
import MatchBanner from "../components/MatchBanner.astro";
import Marquee from "../components/Marquee.astro";
import media from "../data/media.json";
import Gallery from "../components/Gallery.astro";
import site from "../data/site.json";
import { getCollection } from "astro:content";

const news = (await getCollection("news")).sort((a, b) => b.data.date.localeCompare(a.data.date)).slice(0, 3);
const events = (await getCollection("events")).sort((a, b) => a.data.date.localeCompare(b.data.date)).slice(0, 3);
const tickerItems = [
  "Un seul bloc. Une seule voix.",
  "Support positif et respectueux",
  "Bleu & jaune partout",
  "Chants unifies, energie partagee",
  "Toko bloque bango tiii na tiii"
];
---
<BaseLayout title="Accueil" description="Supporters officiels des Leopards. Mobilisation positive, chants unifies et fan experience.">
  {site.matchDay && <MatchBanner label={site.matchDayLabel} href={site.matchDayCTA} ctaLabel={site.matchDayCTALabel} />}
  <section class="relative min-h-[80vh] flex items-center overflow-hidden">
    <!-- Video Background -->
    <video autoplay muted loop playsinline class="absolute inset-0 w-full h-full object-cover -z-20">
      <source src="/videos/hero.mp4" type="video/mp4" />
    </video>
    
    <!-- Overlay -->
    <div class="absolute inset-0 bg-gradient-to-r from-brand-dark/90 to-brand-dark/40 -z-10"></div>
    
    <div class="mx-auto grid max-w-6xl gap-12 px-4 py-20 md:grid-cols-[1.1fr_0.9fr] relative z-10">
      <div class="animate-fade-in-up">
        <p class="text-xs uppercase tracking-[0.4em] text-brand-yellow font-bold">Bloc Leopards</p>
        <h1 class="section-title mt-4 text-5xl md:text-7xl text-white">Un seul bloc. Une seule voix.</h1>
        <p class="mt-4 max-w-2xl text-lg text-slate-200">Le mouvement officiel des supporters pour une mobilisation positive, une tribune unie et une experience fan inoubliable.</p>
        <p class="mt-3 text-sm text-brand-yellow/80">Punchline: Toko bloque bango tiii na tiii 🐆🇨🇩</p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/rejoindre" class="rounded-full bg-brand-yellow px-6 py-3 text-sm font-semibold text-brand-dark pulse-glow hover:bg-white transition-colors">Rejoindre le Bloc</a>
          <a href="/matchs" class="rounded-full border border-white/30 bg-white/10 backdrop-blur-sm px-6 py-3 text-sm font-semibold text-white hover:bg-white/20 transition-colors">Voir la mobilisation</a>
        </div>
        <div class="mt-10 grid gap-6 rounded-3xl border border-white/10 bg-white/5 backdrop-blur-md p-6 shadow-2xl md:grid-cols-3">
          <div>
            <p class="text-xs uppercase tracking-[0.3em] text-brand-yellow font-bold">Support</p>
            <p class="mt-2 text-sm text-slate-300">Chants unifies, coregraphies et coordination par les capos.</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.3em] text-brand-yellow font-bold">Mobilisation</p>
            <p class="mt-2 text-sm text-slate-300">Fan zones, actions digitales et kits supporters officiels.</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.3em] text-brand-yellow font-bold">Respect</p>
            <p class="mt-2 text-sm text-slate-300">Zero violence, discipline en tribune, unite nationale.</p>
          </div>
        </div>
      </div>
      <div class="flex flex-col items-center gap-6 animate-fade-in-up" style="animation-delay: 0.3s">
        <div class="relative w-full max-w-sm rounded-[32px] border border-white/10 bg-white/5 backdrop-blur-md p-6 shadow-2xl float-slow">
          <img src="/brand/logo.png" alt="Bloc Leopards" class="mx-auto h-48 w-auto object-contain drop-shadow-xl" />
          <div class="mt-6 grid gap-3">
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4 text-sm text-slate-200">
              Jour de match: rassemblement officiel + kit chants + fan zone.
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4 text-sm text-slate-200">
              Capos, tambours, drapeaux: coordination totale pour une tribune unie.
            </div>
          </div>
        </div>
        <div class="rounded-full border border-white/20 bg-white/10 backdrop-blur px-5 py-2 text-xs uppercase tracking-[0.3em] text-white">Ambiance live</div>
      </div>
    </div>
  </section>

  <Marquee items={tickerItems} />

  <section class="mx-auto max-w-6xl px-4 py-10">
    <div class="glass-card flex flex-wrap items-center justify-between gap-6 rounded-3xl px-6 py-5 text-sm">
      <div class="flex items-center gap-4">
        <div class="equalizer" aria-hidden="true">
          <span class="eq-bar"></span>
          <span class="eq-bar"></span>
          <span class="eq-bar"></span>
          <span class="eq-bar"></span>
          <span class="eq-bar"></span>
        </div>
        <div>
          <p class="text-xs uppercase tracking-[0.3em] text-slate-500">Chant du jour</p>
          <p class="font-semibold text-slate-800">Un seul bloc, une seule voix, Leopards en route!</p>
        </div>
      </div>
      <a href="/matchs" class="rounded-full border border-slate-300 px-4 py-2 text-xs uppercase tracking-[0.2em] text-slate-700">Voir tous les chants</a>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeader eyebrow="Agenda" title="Prochains evenements" description="DEMO - Calendrier indicatif. Aucun evenement officiel n'est publie ici." />
    <div class="grid gap-6 md:grid-cols-3">
      {events.map((event) => (
        <Card
          title={event.data.title}
          description={`${event.data.date} • ${event.data.time} • ${event.data.location}`}
          meta={event.data.cta}
          image={event.data.image}
          href={`/evenements/${event.slug}`}
          cta="Details"
        />
      ))}
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <SectionHeader eyebrow="Actus" title="Dernieres actualites" description="Infos et annonces DEMO pour la mobilisation." />
      <div class="grid gap-6 md:grid-cols-3">
      {news.map((item) => (
        <Card
          title={item.data.title}
          description={item.data.description}
          meta={item.data.date}
          image={item.data.image}
          href={`/actus/${item.slug}`}
          cta="Lire"
        />
      ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeader eyebrow="Ambiance" title="Galerie officielle" description="Visuels DEMO. L'energie du bloc en images." />
    <Gallery items={media} />
  </section>

  <section class="bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <SectionHeader eyebrow="Institution" title="Partenariat institutionnel" description="Bloc Leopards agit en complementarite avec les missions du Ministere des Sports et des federations." />
      <div class="rounded-3xl border border-slate-200 bg-white p-6 text-sm text-slate-700">
        <p>Nous soutenons les actions officielles en matiere de discipline, jeunesse et promotion du sport. Les annonces officielles restent publiees par les institutions competentes.</p>
        <a class="mt-4 inline-flex text-brand-yellow" href="https://sports.gouv.cd" target="_blank" rel="noopener">Visiter sports.gouv.cd</a>
      </div>
    </div>
  </section>

  <section class="bg-brand-yellow text-brand-dark">
    <div class="mx-auto grid max-w-6xl gap-8 px-4 py-16 md:grid-cols-2">
      <div>
        <p class="text-xs uppercase tracking-[0.3em]">Rejoindre</p>
        <h2 class="section-title mt-2 text-4xl">Rejoins le Bloc Leopards</h2>
        <p class="mt-3 text-sm">Deviens membre officiel, recois le kit supporters, et participe aux fan zones.</p>
        <div class="mt-6 flex flex-wrap gap-4">
          <a href="/rejoindre" class="rounded-full bg-white px-6 py-3 text-sm font-semibold text-brand-yellow">Formulaire d'adhesion</a>
          <a href="/charte" class="rounded-full border border-brand-dark px-6 py-3 text-sm font-semibold">Lire la charte</a>
        </div>
      </div>
      <div class="rounded-3xl bg-white p-6 text-slate-900">
        <p class="text-xs uppercase tracking-[0.3em] text-brand-yellow">Newsletter</p>
        <p class="mt-3 text-sm text-slate-600">Recevoir les convocations de mobilisation, fan zones, et kits officiels.</p>
        <NewsletterForm />
      </div>
    </div>
  </section>
</BaseLayout>
