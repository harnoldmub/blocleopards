---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Card from "../components/Card.astro";
import NewsletterForm from "../components/NewsletterForm.astro";
import MatchBanner from "../components/MatchBanner.astro";
import Marquee from "../components/Marquee.astro";
import media from "../data/media.json";
import Gallery from "../components/Gallery.astro";
import site from "../data/site.json";
import { getCollection } from "astro:content";
import { getSetting } from "../lib/settings";

const partners = [
  { name: "SONAS", logo: "/media/partenaires/LOGO SONAS.png" },
  { name: "Equity BCDC", logo: "/media/partenaires/Logo_EquityBCDC.png" },
  { name: "MFS Groupe", logo: "/media/partenaires/MFS GROUPE.png" },
  { name: "Shalina Healthcare", logo: "/media/partenaires/Shalina-Logo-Blue.png" },
  { name: "Fonarev", logo: "/media/partenaires/logo-fonarev.webp" },
  { name: "Visa", logo: "/media/partenaires/logo-visa.png" },
];

const today = new Date().toISOString().slice(0, 10);
let allEvents: any[] = [];
try { allEvents = (await getCollection("events")).sort((a: any, b: any) => a.data.date.localeCompare(b.data.date)); } catch {}
const upcomingEvents = allEvents.filter((event: any) => event.data.date >= today);
const events = (upcomingEvents.length ? upcomingEvents : allEvents).slice(0, 3);
const FR_MONTHS = ["JAN","FEV","MAR","AVR","MAI","JUIN","JUIL","AOUT","SEPT","OCT","NOV","DEC"];
const getMonth = (d: string) => FR_MONTHS[parseInt(d.split("-")[1]) - 1];
const getDay = (d: string) => parseInt(d.split("-")[2]);
const billeterieActive = (await getSetting("billeterie_active", "true")) !== "false";
const guadalajaraActive = (await getSetting("guadalajara_active", "true")) !== "false";

const tickerItems = [
  "Tous en bleu et jaune.",
  "Tous en maillot Leopards.",
  "Un seul bloc. Une seule voix.",
  "Support positif et respectueux",
  "Bleu & jaune partout",
  "Energie partagee",
  "Toko bloque bango tiii na tiii"
];
---
<BaseLayout title="Accueil" description="Supporters des Leopards. Mobilisation positive, informations verifiees et fan experience.">
  {site.matchDay && <MatchBanner label={site.matchDayLabel} href={site.matchDayCTA} ctaLabel={site.matchDayCTALabel} />}
  <section class="relative min-h-[80vh] flex items-center overflow-hidden">
    <!-- Video Background -->
    <video autoplay muted loop playsinline class="absolute inset-0 w-full h-full object-cover -z-20">
      <source src="/videos/hero.mp4" type="video/mp4" />
    </video>
    
    <!-- Overlay -->
    <div class="absolute inset-0 bg-gradient-to-r from-brand-dark/90 to-brand-dark/40 -z-10"></div>
    
    <div class="mx-auto grid max-w-6xl gap-12 px-4 py-16 md:grid-cols-[1fr_0.9fr] relative z-10">
      <div class="animate-fade-in-up">
        <p class="text-xs uppercase tracking-[0.4em] text-brand-yellow font-bold">Bloc Leopards</p>
        <h1 class="section-title mt-4 text-5xl md:text-7xl text-white">Un seul bloc.</h1>
        <p class="mt-4 max-w-xl text-lg text-slate-200">La tribune congolaise se rassemble: chants, drapeaux, ferveur et discipline.</p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/rejoindre" class="rounded-full bg-brand-yellow px-6 py-3 text-sm font-semibold text-brand-dark pulse-glow hover:bg-white transition-colors">Rejoindre le Bloc</a>
          {guadalajaraActive && <a href="/mondial" class="rounded-full border border-white/30 bg-white/10 backdrop-blur-sm px-6 py-3 text-sm font-semibold text-white hover:bg-white/20 transition-colors">Demande ton billet</a>}
        </div>
      </div>
      <div class="hidden flex-col items-center gap-6 animate-fade-in-up md:flex" style="animation-delay: 0.3s">
        <div class="grid w-full max-w-md grid-cols-2 gap-3 float-slow">
          <img src="/media/ivanor-joie-tribune.jpg" alt="Supporter des Leopards" class="h-64 w-full rounded-3xl border border-white/10 object-cover shadow-2xl" />
          <img src="/media/ivanor-supporter-joie.jpg" alt="Supporter RDC" class="mt-10 h-64 w-full rounded-3xl border border-white/10 object-cover shadow-2xl" />
          <img src="/media/liste-officielle-leopards-2026.jpg" alt="Liste officielle des Leopards" class="col-span-2 h-48 w-full rounded-3xl border border-white/10 object-cover object-top shadow-2xl" />
        </div>
        <div class="rounded-full border border-white/20 bg-white/10 backdrop-blur px-5 py-2 text-xs uppercase tracking-[0.3em] text-white">Ambiance live</div>
      </div>
    </div>
  </section>

  <Marquee items={tickerItems} />

  <section class="mx-auto max-w-6xl px-4 py-10">
    <div class="mb-6 text-center">
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-slate-400">Nos partenaires</p>
      <p class="mt-1 text-lg font-bold text-slate-800">Ils soutiennent le Bloc</p>
    </div>
    <div class="grid grid-cols-3 gap-4 md:grid-cols-6">
      {partners.map((p) => (
        <div class="flex items-center justify-center rounded-2xl border border-slate-200 bg-white p-4 shadow-sm min-h-[80px]">
          <img src={p.logo} alt={p.name} class="max-h-10 w-auto max-w-[100px] object-contain" />
        </div>
      ))}
    </div>
  </section>

  {upcomingEvents.length > 0 && (
    <section class="mx-auto max-w-6xl px-4 py-12">
      <div class="mb-8 text-center">
        <p class="text-xs font-bold uppercase tracking-[0.18em] text-brand-yellow">Agenda</p>
        <p class="mt-1 text-2xl font-bold text-slate-900">Prochains evenements</p>
      </div>
      <div class="flex flex-col gap-4">
        {upcomingEvents.slice(0, 2).map((event: any) => (
          <div class="flex items-center gap-0 overflow-hidden rounded-2xl" style="background:#0d1221;">
            <!-- Accent stripe -->
            <div class="w-1.5 self-stretch flex-shrink-0" style="background:linear-gradient(to bottom,#f7d618,#e8502a);"></div>
            <!-- Date block -->
            <div class="flex w-28 flex-shrink-0 flex-col items-center justify-center px-5 py-6 text-center">
              <span class="text-xs font-bold uppercase tracking-widest" style="color:#f7d618;">{getMonth(event.data.date)}</span>
              <span class="mt-0.5 text-5xl font-black leading-none text-white">{getDay(event.data.date)}</span>
              <span class="mt-1.5 text-xs text-slate-400">{event.data.time}</span>
            </div>
            <!-- Divider -->
            <div class="w-px self-stretch" style="background:rgba(255,255,255,0.08);"></div>
            <!-- Info block -->
            <div class="flex-1 px-6 py-6">
              <p class="text-xs font-bold uppercase tracking-[0.18em]" style="color:#f7d618;">{event.data.description}</p>
              <h3 class="mt-1 text-xl font-black uppercase text-white">{event.data.title}</h3>
              <p class="mt-1.5 text-sm text-slate-400">{event.data.location}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-10 text-center">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-yellow">Bloc Leopards</p>
        <p class="mt-2 text-2xl font-bold text-slate-900">Rejoins le Bloc en tribune</p>
        <p class="mt-2 text-sm text-slate-500 max-w-sm mx-auto">Soutiens les Léopards en tribune. Programme diaspora pour le Mondial 2026.</p>
        {guadalajaraActive && (
          <a href="/mondial" class="mt-6 inline-flex items-center gap-2 rounded-full px-8 py-3 text-sm font-semibold" style="background:linear-gradient(135deg,#1c2e8f,#0b0f1f);color:#f7d618;border:1px solid rgba(247,214,24,0.3);box-shadow:0 4px 20px rgba(28,46,143,0.35);">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 9a3 3 0 0 1 0 6V19a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-4a3 3 0 0 1 0-6V5a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2z"/><line x1="9" y1="12" x2="15" y2="12"/></svg>
            <span>Demande ton billet</span>
          </a>
        )}
      </div>
    </section>
  )}

  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="grid gap-8 md:grid-cols-[0.9fr_1.4fr] md:items-center">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-brand-yellow">52 ans apres</p>
        <h2 class="section-title mt-3 text-4xl text-slate-950">Les Leopards sont de retour</h2>
        <p class="mt-4 text-sm leading-6 text-slate-600">Premiere nation d'Afrique subsaharienne a avoir joue une Coupe du monde, la RDC retrouve la scene mondiale avec ambition.</p>
        <a href="/actus/2026-05-25-retour-mondial-52-ans" class="mt-6 inline-flex rounded-full bg-brand-yellow px-5 py-3 text-sm font-semibold text-brand-dark">Lire le contexte</a>
      </div>
      <video class="aspect-video w-full rounded-3xl border border-slate-200 bg-slate-950 object-cover shadow-deep" autoplay muted controls playsinline preload="metadata">
        <source src="/videos/retour-mondial-52-ans.mp4" type="video/mp4" />
      </video>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeader eyebrow="Agenda" title="Prochains evenements" description="Rendez-vous reels autour de la preparation des Leopards." />
    <div class="grid gap-6 md:grid-cols-3">
      {events.map((event) => (
        <Card
          title={event.data.title}
          description={`${event.data.date} • ${event.data.time} • ${event.data.location}`}
          meta={event.data.cta}
          image={event.data.image}
          href={`/evenements/${event.slug}`}
          cta="Details"
        />
      ))}
    </div>
  </section>

  <section class="mx-auto grid max-w-6xl gap-8 px-4 py-16 md:grid-cols-[1.15fr_0.85fr]">
    <div>
      <SectionHeader eyebrow="Video" title="Hommage a la diaspora" description="Liege, Marbella, les chants et les couleurs en mouvement." />
      <div class="mx-auto max-w-sm">
        <video class="aspect-[9/16] w-full rounded-3xl border border-slate-200 bg-slate-950 object-cover shadow-deep" controls poster="/media/hommage-diaspora-cover.jpg">
          <source src="/videos/hommage-diaspora-match-amical.mp4" type="video/mp4" />
        </video>
      </div>
    </div>
    <div class="flex flex-col justify-center rounded-3xl border border-slate-200 bg-white p-6 shadow-deep">
      <p class="text-xs uppercase tracking-[0.3em] text-brand-yellow">Diaspora</p>
      <h3 class="section-title mt-3 text-4xl">De Liege a Marbella</h3>
      <p class="mt-3 text-sm leading-6 text-slate-600">Un hommage aux supporters qui portent le drapeau partout ou les Leopards jouent.</p>
      <audio class="mt-6 w-full" controls src="/audio/hommage-diaspora.mp3"></audio>
      <a href="/actus/2026-05-25-hommage-diaspora" class="mt-6 inline-flex rounded-full bg-brand-yellow px-5 py-3 text-sm font-semibold text-brand-dark">Voir l'article</a>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeader eyebrow="Ambiance" title="Galerie" description="L'energie du bloc en images." />
    <Gallery items={media} />
  </section>


  <section class="bg-brand-yellow text-brand-dark">
    <div class="mx-auto grid max-w-6xl gap-8 px-4 py-16 md:grid-cols-2">
      <div>
        <p class="text-xs uppercase tracking-[0.3em]">Rejoindre</p>
        <h2 class="section-title mt-2 text-4xl">Rejoins le Bloc Leopards</h2>
        <p class="mt-3 text-sm">Rejoins le mouvement, recois le kit supporters, et participe aux mobilisations confirmees.</p>
        <div class="mt-6 flex flex-wrap gap-4">
          <a href="/rejoindre" class="rounded-full bg-white px-6 py-3 text-sm font-semibold text-brand-yellow">Formulaire d'adhesion</a>
          <a href="/charte" class="rounded-full border border-brand-dark px-6 py-3 text-sm font-semibold">Lire la charte</a>
        </div>
      </div>
      <div class="rounded-3xl bg-white p-6 text-slate-900">
        <p class="text-xs uppercase tracking-[0.3em] text-brand-yellow">Newsletter</p>
        <p class="mt-3 text-sm text-slate-600">Recevoir les mobilisations confirmees, fan zones, et kits supporters.</p>
        <NewsletterForm />
      </div>
    </div>
  </section>
</BaseLayout>
