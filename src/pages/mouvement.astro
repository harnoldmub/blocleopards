---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
---
<BaseLayout title="Mouvement" description="Mission, vision et organisation du Bloc Leopards.">
  <PageHero title="Le Mouvement" subtitle="Une force de soutien populaire, responsable et organisee" image="/media/web-rdc-supporter.jpg" />
  <section class="bg-stadium">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <SectionHeader eyebrow="Contexte" title="Pourquoi le Bloc existe" description="La RDC retrouve la Coupe du monde apres 52 ans d'attente. Cette ferveur demande une organisation positive, lisible et respectueuse." />
      <div class="grid gap-8 md:grid-cols-3">
        <div class="rounded-2xl border border-slate-200 bg-white p-6">
          <h3 class="text-lg font-semibold">Mission</h3>
          <p class="mt-2 text-sm text-slate-600">Rassembler les supporters des Leopards autour d'une mobilisation responsable: couleurs, chants, informations fiables et respect des consignes.</p>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-6">
          <h3 class="text-lg font-semibold">Vision</h3>
          <p class="mt-2 text-sm text-slate-600">Faire de chaque rendez-vous des Leopards un moment d'unite nationale, a Kinshasa comme dans la diaspora.</p>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-6">
          <h3 class="text-lg font-semibold">Valeurs</h3>
          <p class="mt-2 text-sm text-slate-600">Unite, respect, discipline, fierte et inclusion. Le soutien doit grandir l'image de la RDC.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeader eyebrow="Organisation" title="Comment on se mobilise" description="Une methode simple pour eviter les rumeurs, orienter les supporters et amplifier les messages utiles." />
    <div class="grid gap-6 md:grid-cols-2">
      <div class="rounded-2xl border border-slate-200 bg-white p-6">
        <h3 class="text-lg font-semibold">Avant match</h3>
        <ul class="mt-3 text-sm text-slate-600 list-disc pl-4">
          <li>Verifier les horaires, lieux et sources avant publication.</li>
          <li>Partager les points de rassemblement et consignes pratiques.</li>
          <li>Preparer les visuels, drapeaux et messages de mobilisation.</li>
        </ul>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6">
        <h3 class="text-lg font-semibold">Pendant match</h3>
        <ul class="mt-3 text-sm text-slate-600 list-disc pl-4">
          <li>Soutien continu, sans insultes ni messages discriminatoires.</li>
          <li>Respect des stewards, familles et autres supporters.</li>
          <li>Relais des moments forts avec photos et videos responsables.</li>
        </ul>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6">
        <h3 class="text-lg font-semibold">Apres match</h3>
        <ul class="mt-3 text-sm text-slate-600 list-disc pl-4">
          <li>Recap des informations verifiees et prochains rendez-vous.</li>
          <li>Remerciements aux supporters sur place et a distance.</li>
          <li>Collecte des retours pour ameliorer les prochaines mobilisations.</li>
        </ul>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6">
        <h3 class="text-lg font-semibold">Activations digitales</h3>
        <ul class="mt-3 text-sm text-slate-600 list-disc pl-4">
          <li>Messages courts, factuels et positifs.</li>
          <li>Sources citees pour les informations sportives.</li>
          <li>Moderation ferme contre les fausses nouvelles et attaques personnelles.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <SectionHeader eyebrow="Roles" title="Les equipes du Bloc" description="Chaque role sert la meme idee: soutenir les Leopards sans brouiller les sources officielles." />
      <div class="grid gap-6 md:grid-cols-3">
        <div class="rounded-2xl border border-slate-200 bg-white p-6">
          <h3 class="text-lg font-semibold">Animation</h3>
          <p class="mt-2 text-sm text-slate-600">Ambiance, chants, points de rassemblement et coordination des supporters presents.</p>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-6">
          <h3 class="text-lg font-semibold">Media</h3>
          <p class="mt-2 text-sm text-slate-600">Photos, videos, galerie et respect des droits d'image des supporters.</p>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-6">
          <h3 class="text-lg font-semibold">Veille</h3>
          <p class="mt-2 text-sm text-slate-600">Verification des sources: FIFA, CAF, Federation, medias cites et communications des organisateurs.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeader eyebrow="Sources" title="Nos reperes fiables" description="Les informations sportives sensibles sont recoupees avant d'etre relayees." />
    <div class="grid gap-4 text-sm md:grid-cols-3">
      <a class="rounded-2xl border border-slate-200 bg-white p-5 font-semibold text-brand-yellow" href="https://www.fifa.com/en/tournaments/mens/worldcup/canadamexicousa2026/teams/congo-dr" target="_blank" rel="noopener">FIFA - equipe Congo DR</a>
      <a class="rounded-2xl border border-slate-200 bg-white p-5 font-semibold text-brand-yellow" href="https://www.cafonline.com/fifa-world-cup/news/dr-congo-end-52-year-world-cup-wait-with-extra-time-victory-over-jamaica/" target="_blank" rel="noopener">CAF - qualification 2026</a>
      <a class="rounded-2xl border border-slate-200 bg-white p-5 font-semibold text-brand-yellow" href="https://digitalcongo.org/detail15035-mondial-2026-les-leopards-s-offrent-le-danemark-et-le-chili-en-amical" target="_blank" rel="noopener">Digital Congo - amicaux</a>
    </div>
  </section>
</BaseLayout>
