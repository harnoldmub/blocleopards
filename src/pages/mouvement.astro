---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
---
<BaseLayout title="Mouvement" description="Mission, vision et equipes du Bloc Leopards.">
  <PageHero title="Le Mouvement" subtitle="Supporters officiels, energie populaire" image="/media/ambiance-1.svg" />
  <section class="bg-stadium">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <div class="grid gap-8 md:grid-cols-3">
        <div class="rounded-2xl border border-slate-200 bg-white p-6">
          <h3 class="text-lg font-semibold">Mission</h3>
          <p class="mt-2 text-sm text-slate-600">Unifier les supporters autour d'un chant commun, d'une discipline exemplaire et d'une energie positive.</p>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-6">
          <h3 class="text-lg font-semibold">Vision</h3>
          <p class="mt-2 text-sm text-slate-600">Faire du soutien aux Leopardes un modele d'unite nationale et de respect, sur le terrain comme en ligne.</p>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-6">
          <h3 class="text-lg font-semibold">Valeurs</h3>
          <p class="mt-2 text-sm text-slate-600">Unite, respect, discipline, fierte, excellence et inclusion.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeader eyebrow="Animation" title="Comment on anime" description="Une organisation claire pour une tribune en harmonie." />
    <div class="grid gap-6 md:grid-cols-2">
      <div class="rounded-2xl border border-slate-200 bg-white p-6">
        <h3 class="text-lg font-semibold">Avant match</h3>
        <ul class="mt-3 text-sm text-slate-600 list-disc pl-4">
          <li>Brief capos et securite.</li>
          <li>Distribution des chants et visuels.</li>
          <li>Accueil des supporters et orientation.</li>
        </ul>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6">
        <h3 class="text-lg font-semibold">Pendant match</h3>
        <ul class="mt-3 text-sm text-slate-600 list-disc pl-4">
          <li>Chants unifies avec signal des capos.</li>
          <li>Coregraphies et gestes coordonnes.</li>
          <li>Gestion positive des temps forts.</li>
        </ul>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6">
        <h3 class="text-lg font-semibold">Apres match</h3>
        <ul class="mt-3 text-sm text-slate-600 list-disc pl-4">
          <li>Debrief express et retours d'experience.</li>
          <li>Nettoyage des tribunes.</li>
          <li>Contenus photos et recap pour les fans.</li>
        </ul>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6">
        <h3 class="text-lg font-semibold">Activations digitales</h3>
        <ul class="mt-3 text-sm text-slate-600 list-disc pl-4">
          <li>Hashtags officiels et messages positifs.</li>
          <li>Visuels de campagne partages par les fans.</li>
          <li>Moderation respectueuse.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <SectionHeader eyebrow="Equipes" title="Roles & equipes" description="Chaque role renforce l'unite et la discipline du bloc." />
      <div class="grid gap-6 md:grid-cols-3">
        <div class="rounded-2xl border border-slate-200 bg-white p-6">
          <h3 class="text-lg font-semibold">Capos</h3>
          <p class="mt-2 text-sm text-slate-600">Meneurs de chants, coordination des tribunes, lien direct avec l'organisation.</p>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-6">
          <h3 class="text-lg font-semibold">Equipe visuelle</h3>
          <p class="mt-2 text-sm text-slate-600">Banderoles, drapeaux, coregraphies, distribution de kits.</p>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-6">
          <h3 class="text-lg font-semibold">Equipe digitale</h3>
          <p class="mt-2 text-sm text-slate-600">Social media, contenus officiels, veille et modération.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
