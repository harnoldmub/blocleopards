---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import kit from "../data/kit.json";
---
<BaseLayout title="Kit supporters" description="Chants, bannières et wallpapers Bloc Leopards.">
  <section class="mx-auto max-w-5xl px-4 py-16">
    <SectionHeader eyebrow="Kit" title="Kit supporters" description="Ressources pratiques pour soutenir les Leopards de facon positive et coordonnee." />
    <div class="rounded-3xl border border-slate-200 bg-white p-6 text-sm text-slate-700">
      <p>Telechargements disponibles:</p>
      <ul class="mt-3 list-disc pl-4">
        <li><a class="text-brand-yellow" href="/downloads/kit-supporters.pdf">Kit supporters PDF</a></li>
        <li><a class="text-brand-yellow" href="/downloads/charte-bloc-leopards.pdf">Charte PDF</a></li>
      </ul>
      <p class="mt-6 text-xs uppercase tracking-[0.3em] text-brand-yellow">Chants inclus</p>
      <div class="mt-3 grid gap-3 md:grid-cols-2">
        {kit.chants.map((chant) => (
          <div class="rounded-2xl border border-slate-200 bg-white p-3">{chant}</div>
        ))}
      </div>
    </div>
    <div class="mt-8 grid gap-4 md:grid-cols-3">
      <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5 text-sm text-slate-700">
        <p class="font-semibold text-slate-900">Avant de publier</p>
        <p class="mt-2">Verifier la date, le lieu et la source avant de partager une info match.</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5 text-sm text-slate-700">
        <p class="font-semibold text-slate-900">Pendant le match</p>
        <p class="mt-2">Filmer sans gener les autres supporters et eviter les contenus insultants.</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5 text-sm text-slate-700">
        <p class="font-semibold text-slate-900">Apres le match</p>
        <p class="mt-2">Partager photos et recaps avec contexte, credit et respect du droit a l'image.</p>
      </div>
    </div>
  </section>
</BaseLayout>
