---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { requireDatabase, hasDatabase } from "../../lib/neon";
import { getSetting } from "../../lib/settings";

// Fetch live counts
let totalInscriptions = 0;
let totalVerified = 0;
let totalDuplicates = 0;
let tiragePublie = false;
let winners: any[] = [];
let tirageHistory: any[] = [];
let distribution: any[] = [];

if (hasDatabase) {
  try {
    const sql = requireDatabase();
    const [stats] = await sql`
      select
        count(*)::integer as total,
        count(*) filter (where verification_status = 'verified')::integer as verified,
        count(*) filter (where verification_status = 'flagged')::integer as flagged
      from mondial_inscriptions
    `;
    const [docStats] = await sql`
      select count(*)::integer as duplicates
      from mondial_inscriptions
      where jsonb_array_length(anti_fraud_flags) > 0
    `;
    totalInscriptions = stats?.total || 0;
    totalVerified = stats?.verified || 0;
    totalDuplicates = docStats?.duplicates || 0;

    const geoRows = await sql`
      select
        case
          when lower(country) in ('états-unis', 'etats-unis', 'usa', 'united states', 'united states of america')
            then coalesce(nullif(state_us, ''), 'États-Unis non renseigné')
          else coalesce(nullif(country, ''), 'Pays non renseigné')
        end as location,
        count(*)::integer as count
      from mondial_inscriptions
      group by 1
      order by count desc, location asc
    `;
    const geoTotal = geoRows.reduce((sum: number, row: any) => sum + Number(row.count || 0), 0);
    const palette = ["#f7d618", "#007fff", "#e2e8f0", "#a855f7", "#f97316"];
    const stateCodes: Record<string, string> = {
      Alabama: "AL", Alaska: "AK", Arizona: "AZ", Arkansas: "AR", Californie: "CA", California: "CA",
      Colorado: "CO", Connecticut: "CT", Delaware: "DE", Floride: "FL", Florida: "FL", Géorgie: "GA",
      Georgia: "GA", Texas: "TX", "New York": "NY", Illinois: "IL", Washington: "WA",
      "District of Columbia": "DC"
    };
    const codeLabels: Record<string, string> = {
      AL: "Alabama (AL)", AK: "Alaska (AK)", AZ: "Arizona (AZ)", AR: "Arkansas (AR)",
      CA: "Californie (CA)", CO: "Colorado (CO)", CT: "Connecticut (CT)", DE: "Delaware (DE)",
      FL: "Floride (FL)", GA: "Géorgie (GA)", TX: "Texas (TX)", NY: "New York (NY)",
      IL: "Illinois (IL)", WA: "Washington (WA)", DC: "District of Columbia (DC)"
    };
    const formatLocation = (location: string) => {
      if (codeLabels[location]) return codeLabels[location];
      const code = stateCodes[location];
      return code ? `${location} (${code})` : location;
    };
    if (geoTotal > 0) {
      const topRows = geoRows.slice(0, 4);
      const otherCount = geoRows.slice(4).reduce((sum: number, row: any) => sum + Number(row.count || 0), 0);
      distribution = [
        ...topRows.map((row: any, index: number) => ({
          state: formatLocation(row.location),
          count: Number(row.count || 0),
          pct: Math.round((Number(row.count || 0) / geoTotal) * 100),
          value: (Number(row.count || 0) / geoTotal) * 100,
          color: palette[index]
        })),
        ...(otherCount > 0 ? [{
          state: "Autres",
          count: otherCount,
          pct: Math.round((otherCount / geoTotal) * 100),
          value: (otherCount / geoTotal) * 100,
          color: palette[4]
        }] : [])
      ];
    }

    tiragePublie = (await getSetting("mondial_tirage_publie", "false")) === "true";

    if (tiragePublie) {
      winners = await sql`
        with latest_draws as (
          select distinct on (match_key) match_key, published
          from mondial_tirage_logs
          where match_key is not null
          order by match_key, ran_at desc
        )
        select
          m.first_name,
          m.city,
          m.state_us,
          m.country,
          m.matchs_vises,
          m.selected_match_key,
          p.id as portrait_id
        from mondial_inscriptions m
        left join justificatifs_identite p
          on p.inscription_id = m.id
          and p.type_document = 'PHOTO'
          and p.deleted_at is null
        join latest_draws d
          on d.match_key = m.selected_match_key
          and d.published = true
        where m.ticket_given_at is not null
        order by m.selected_match_key asc, m.ticket_given_at asc
      `;
    }

    // Always fetch draw history (even before publication)
    try {
      tirageHistory = await sql`
        select id, match_key, candidates_count, winners_count, published, ran_at
        from mondial_tirage_logs
        order by ran_at asc
      `;
    } catch { /* table may not exist yet */ }
  } catch (err) {
    console.error("Error fetching transparency stats:", err);
  }
}

const matchLabels: Record<string, string> = {
  houston: "RDC vs Portugal",
  guadalajara: "RDC vs Colombie",
  atlanta: "RDC vs Ouzbékistan"
};

const groupedWinners = winners.reduce((groups: Record<string, any[]>, winner: any) => {
  const key = winner.selected_match_key || "non-renseigne";
  groups[key] = groups[key] || [];
  groups[key].push(winner);
  return groups;
}, {});

let distributionOffset = 0;
---
<BaseLayout title="Transparence du Tirage — Mondial 2026" description="Découvrez le fonctionnement simple du tirage au sort par match pour les billets des Léopards au Mondial 2026.">
  <div class="bg-[#07090f] text-white py-16 px-4 min-h-screen font-sans relative">
    
    <div class="absolute inset-0 bg-radial-at-t from-blue-950/20 via-transparent to-transparent pointer-events-none"></div>

    <div class="max-w-4xl mx-auto relative z-10">
      
      <!-- Page Header -->
      <div class="text-center mb-16">
        <span class="text-xs uppercase tracking-[0.2em] text-[#f7d618] font-bold">Équité & clarté</span>
        <h1 class="font-bebas text-5xl md:text-6xl tracking-wide mt-2 text-white">
          TRANSPARENCE <span class="text-[#f7d618]">DU TIRAGE</span>
        </h1>
        <p class="text-slate-400 text-sm md:text-base max-w-xl mx-auto mt-4 leading-relaxed">
          Le Bloc Léopards organise un tirage simple par match : seuls les dossiers vérifiés du match choisi entrent dans le tirage, puis le quota disponible est sélectionné aléatoirement.
        </p>
      </div>

      <!-- Live Pipeline Timeline -->
      <div class="bg-white/5 border border-white/10 rounded-3xl p-8 mb-12">
        <h2 class="font-bebas text-2xl text-white mb-8 tracking-wide">ÉTAT DU PARCOURS D'INSCRIPTION</h2>
        
        <div class="grid gap-6 md:grid-cols-5 relative">
          <!-- Timeline progress steps -->
          <div class="flex flex-col items-center text-center p-4 bg-black/20 rounded-2xl border border-white/5">
            <span class="text-2xl mb-2">📥</span>
            <div class="text-[10px] uppercase tracking-wider text-slate-500 font-bold mb-1">Inscriptions</div>
            <div class="font-bebas text-3xl text-[#f7d618] count-up" data-target={totalInscriptions}>{totalInscriptions}</div>
            <p class="text-[10px] text-slate-400 mt-1">Candidatures reçues</p>
          </div>
          
          <div class="flex flex-col items-center text-center p-4 bg-black/20 rounded-2xl border border-white/5">
            <span class="text-2xl mb-2">🛡️</span>
            <div class="text-[10px] uppercase tracking-wider text-slate-500 font-bold mb-1">Vérifiées</div>
            <div class="font-bebas text-3xl text-emerald-400 count-up" data-target={totalVerified}>{totalVerified}</div>
            <p class="text-[10px] text-slate-400 mt-1">Identités validées</p>
          </div>

          <div class="flex flex-col items-center text-center p-4 bg-black/20 rounded-2xl border border-white/5">
            <span class="text-2xl mb-2">🚫</span>
            <div class="text-[10px] uppercase tracking-wider text-slate-500 font-bold mb-1">Doublons</div>
            <div class="font-bebas text-3xl text-red-400 count-up" data-target={totalDuplicates}>{totalDuplicates}</div>
            <p class="text-[10px] text-slate-400 mt-1">Éliminés</p>
          </div>

          <div class="flex flex-col items-center text-center p-4 bg-black/20 rounded-2xl border border-white/5">
            <span class="text-2xl mb-2">🗳️</span>
            <div class="text-[10px] uppercase tracking-wider text-slate-500 font-bold mb-1">Date Tirage</div>
            <div class="font-bebas text-xl text-blue-400 mt-1.5 leading-none">15 JUIN 2026</div>
            <p class="text-[10px] text-slate-400 mt-3">Date de clôture</p>
          </div>

          <div class={`flex flex-col items-center text-center p-4 bg-black/20 rounded-2xl border ${tiragePublie ? "border-emerald-500/30" : "border-white/5"}`}>
            <span class="text-2xl mb-2" style="font-size:1.5rem;display:block;">→</span>
            <div class="text-[10px] uppercase tracking-wider text-slate-500 font-bold mb-1">Résultats</div>
            {tiragePublie ? (
              <div class="font-bebas text-sm text-emerald-400 mt-2">Publié</div>
            ) : (
              <div class="font-bebas text-sm text-slate-500 mt-2">En attente</div>
            )}
            <p class="text-[10px] text-slate-400 mt-3.5">
              {tiragePublie ? `${winners.length} sélectionnés` : "Publication publique"}
            </p>
          </div>
        </div>
      </div>

      <!-- Donut Chart Grid -->
      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <!-- Distribution Donut -->
        <div class="bg-white/5 border border-white/10 rounded-3xl p-8 flex flex-col justify-center">
          <h3 class="font-bebas text-xl text-white mb-6 tracking-wide text-center md:text-left">RÉPARTITION GÉOGRAPHIQUE</h3>
          
          {distribution.length > 0 ? (
          <div class="flex flex-col sm:flex-row items-center gap-8 justify-center">
            <!-- Donut SVG -->
            <div class="relative w-36 h-36 flex-shrink-0">
              <svg viewBox="0 0 36 36" class="w-full h-full transform -rotate-90">
                <!-- Outer circle / gaps -->
                <circle cx="18" cy="18" r="15.915" fill="none" stroke="#1e293b" stroke-width="3"></circle>
                {distribution.map((d) => {
                  const offset = distributionOffset;
                  distributionOffset += d.value;
                  return (
                    <circle
                      cx="18"
                      cy="18"
                      r="15.915"
                      fill="none"
                      stroke={d.color}
                      stroke-width="3.5"
                      stroke-dasharray={`${d.value} ${100 - d.value}`}
                      stroke-dashoffset={-offset}
                      class="transition-all duration-1000"
                    />
                  );
                })}
              </svg>
              <!-- Center Text -->
              <div class="absolute inset-0 flex flex-col items-center justify-center">
                <span class="text-xs text-slate-400 font-bold uppercase tracking-wider">Total</span>
                <span class="font-bebas text-xl text-white">100%</span>
              </div>
            </div>

            <!-- Legend -->
            <div class="flex-1 space-y-2">
              {distribution.map((d) => (
                <div class="flex items-center justify-between text-xs">
                  <div class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full" style={{ backgroundColor: d.color }}></span>
                    <span class="text-slate-300 font-medium">{d.state}</span>
                  </div>
                  <span class="font-bold text-white">{d.pct}%</span>
                </div>
              ))}
            </div>
          </div>
          ) : (
            <div class="rounded-2xl border border-white/10 bg-black/20 p-6 text-center">
              <p class="text-sm font-semibold text-slate-300">Aucune donnée géographique disponible</p>
              <p class="mt-2 text-xs text-slate-500">La répartition apparaîtra dès les premières inscriptions.</p>
            </div>
          )}
        </div>

        <!-- Fraud Prevention Info -->
        <div class="bg-white/5 border border-white/10 rounded-3xl p-8 flex flex-col justify-center">
          <h3 class="font-bebas text-xl text-white mb-4 tracking-wide">ANTI-FRAUDE & SÉCURITÉ</h3>
          <p class="text-xs text-slate-300 leading-relaxed mb-4">
            Pour assurer l'égalité des chances, nous déployons des contrôles rigoureux :
          </p>
          <ul class="text-xs text-slate-400 space-y-3">
            <li class="flex items-start gap-2">
              <span class="text-[#f7d618]">✓</span>
              <span><strong>Une seule inscription par personne :</strong> Validation croisée de l'adresse email, du numéro de téléphone, et de la pièce d'identité.</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[#f7d618]">✓</span>
              <span><strong>Vérification d'identité sécurisée :</strong> Comparaison et validation de chaque document d'identité par l'équipe administrative.</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[#f7d618]">✓</span>
              <span><strong>Suppression RGPD :</strong> Toutes les pièces d'identité chargées sont chiffrées puis supprimées définitivement dès la publication du tirage.</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- ─── RÉSULTATS DU TIRAGE (affiché uniquement quand publié) ─── -->
      {tiragePublie && winners.length > 0 && (
        <div class="mb-12">
          <div class="text-center mb-8">
            <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 text-xs font-bold uppercase tracking-wider mb-4">
              Tirage publié · {winners.length} sélectionnés
            </span>
            <h2 class="font-bebas text-3xl text-white tracking-wide">LISTE DES SÉLECTIONNÉS</h2>
            <p class="text-slate-400 text-xs mt-2 max-w-lg mx-auto">
              Les supporters ci-dessous ont été sélectionnés par match. Chacun sera contacté directement.
            </p>
          </div>

          <div class="space-y-6 mb-8">
            {Object.entries(groupedWinners).map(([matchKey, matchWinners]) => (
              <div class="bg-black/20 border border-white/10 rounded-3xl p-4 md:p-5">
                <div class="flex flex-wrap items-center justify-between gap-2 mb-4">
                  <h3 class="font-bebas text-xl text-white tracking-wide">
                    {matchLabels[matchKey] || "Match non renseigné"}
                  </h3>
                  <span class="rounded-full border border-emerald-500/30 bg-emerald-500/10 px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-emerald-400">
                    {matchWinners.length} sélectionné{matchWinners.length > 1 ? "s" : ""}
                  </span>
                </div>

                <div class="grid gap-3 sm:grid-cols-2 md:grid-cols-3">
                  {matchWinners.map((w: any, i: number) => (
                    <div class="bg-white/5 border border-emerald-500/20 rounded-2xl p-4 flex items-center gap-3">
                      {w.portrait_id ? (
                        <img
                          src={`/api/mondial/photo?id=${w.portrait_id}`}
                          alt={`Photo de ${w.first_name}`}
                          class="h-12 w-12 flex-shrink-0 rounded-2xl border border-emerald-500/30 object-cover"
                          loading="lazy"
                        />
                      ) : (
                        <div class="flex-shrink-0 w-12 h-12 rounded-2xl bg-emerald-500/15 border border-emerald-500/30 flex items-center justify-center">
                          <span class="text-emerald-400 font-bebas text-sm">{i + 1}</span>
                        </div>
                      )}
                      <div class="min-w-0">
                        <div class="flex items-center gap-2">
                          <span class="flex h-6 w-6 items-center justify-center rounded-full bg-emerald-500/15 text-emerald-400 font-bebas text-[10px]">{i + 1}</span>
                          <p class="font-semibold text-white text-sm truncate">{w.first_name}</p>
                        </div>
                        <p class="text-slate-400 text-[10px] truncate">
                          {w.city}{w.state_us ? `, ${w.state_us}` : ""} — {w.country}
                        </p>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {!tiragePublie && (
        <div class="mb-12 text-center py-12 bg-white/5 border border-white/10 rounded-3xl">
          <p class="text-slate-400 text-sm">Le tirage n'a pas encore été publié.</p>
          <p class="text-slate-500 text-xs mt-2">Les résultats apparaîtront ici dès la publication officielle.</p>
        </div>
      )}

      <!-- ─── HISTORIQUE DES TIRAGES ─── -->
      {tirageHistory.length > 0 && (
        <div class="mb-12">
          <div class="text-center mb-6">
            <h2 class="font-bebas text-2xl text-white tracking-wide">HISTORIQUE DES TIRAGES</h2>
            <p class="text-slate-400 text-xs mt-2">Chaque tirage lancé par l'équipe est conservé avec son match, son quota et son statut de publication.</p>
          </div>

          <div class="space-y-3">
            {tirageHistory.map((log: any, i: number) => (
              <div class={`rounded-2xl border p-5 flex flex-wrap items-center gap-4 ${log.published ? "bg-emerald-950/20 border-emerald-500/30" : "bg-white/3 border-white/8"}`}>
                <!-- Index + statut -->
                <div class="flex items-center gap-3 min-w-[120px]">
                  <span class={`w-7 h-7 rounded-full flex items-center justify-center text-xs font-bebas flex-shrink-0 ${log.published ? "bg-emerald-500/20 text-emerald-400 border border-emerald-500/40" : "bg-white/5 text-slate-400 border border-white/10"}`}>
                    {i + 1}
                  </span>
                  <span class={`text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full border ${log.published ? "bg-emerald-500/10 text-emerald-400 border-emerald-500/30" : "bg-white/5 text-slate-500 border-white/10"}`}>
                    {log.published ? "Publié" : "Non publié"}
                  </span>
                </div>

                <!-- Date -->
                <div class="min-w-[140px]">
                  <p class="text-[10px] text-slate-500 uppercase tracking-wider">Date</p>
                  <p class="text-xs text-slate-300 font-mono mt-0.5">
                    {new Date(log.ran_at).toLocaleString("fr-FR", { day:"2-digit", month:"short", year:"numeric", hour:"2-digit", minute:"2-digit" })}
                  </p>
                </div>

                <!-- Candidats / Gagnants -->
                <div class="min-w-[120px]">
                  <p class="text-[10px] text-slate-500 uppercase tracking-wider">Candidats → Gagnants</p>
                  <p class="text-xs text-white font-semibold mt-0.5">{log.candidates_count} → {log.winners_count}</p>
                </div>

                <!-- Match -->
                <div class="flex-1 min-w-[180px]">
                  <p class="text-[10px] text-slate-500 uppercase tracking-wider">Match</p>
                  <p class="text-xs text-[#f7d618] font-semibold mt-0.5">{matchLabels[log.match_key] || "Match non renseigné"}</p>
                </div>
              </div>
            ))}
          </div>

          {tirageHistory.length > 1 && !tirageHistory.some((l: any) => l.published) && (
            <p class="text-slate-500 text-xs text-center mt-4">Aucun tirage n'a encore été publié.</p>
          )}
        </div>
      )}

      <!-- FAQ Section -->
      <div class="bg-white/5 border border-white/10 rounded-3xl p-8">
        <h2 class="font-bebas text-2xl text-white mb-6 tracking-wide text-center">COMMENT FONCTIONNE LE TIRAGE</h2>
        
        <div class="space-y-6 text-sm">
          <div class="border-b border-white/5 pb-4">
            <h4 class="font-bold text-white mb-2">Comment fonctionne le tirage au sort ?</h4>
            <p class="text-slate-400 text-xs leading-relaxed">
              L'équipe choisit un match, indique le quota de billets disponibles, puis lance le tirage. Le système prend uniquement les personnes vérifiées qui se sont inscrites pour ce match et sélectionne aléatoirement le nombre de personnes demandé.
            </p>
          </div>

          <div class="border-b border-white/5 pb-4">
            <h4 class="font-bold text-white mb-2">Pourquoi le tirage se fait-il par match ?</h4>
            <p class="text-slate-400 text-xs leading-relaxed">
              Chaque supporter choisit les matchs qui l'intéressent au moment de l'inscription. Le tirage respecte ce choix : une personne inscrite pour Houston ne sera pas tirée pour Atlanta si elle n'a pas choisi ce match.
            </p>
          </div>

          <div>
            <h4 class="font-bold text-white mb-2">Que voit le public après publication ?</h4>
            <p class="text-slate-400 text-xs leading-relaxed">
              Après publication, la page affiche les personnes sélectionnées par match avec leur prénom, leur ville, leur pays et leur photo portrait lorsqu'elle est disponible. Les documents d'identité restent privés.
            </p>
          </div>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .font-bebas {
    font-family: 'Bebas Neue', sans-serif;
  }
</style>

<script>
  // ── Count-up animation ────────────────────────────────────────────────────
  const countUpEls = document.querySelectorAll('.count-up');
  countUpEls.forEach((el) => {
    const target = parseInt(el.getAttribute('data-target') || '0', 10);
    const duration = 1500; // 1.5s
    const stepTime = Math.abs(Math.floor(duration / target));
    let current = 0;
    
    if (target === 0) return;
    
    const timer = setInterval(() => {
      current += Math.ceil(target / 40);
      if (current >= target) {
        el.textContent = String(target);
        clearInterval(timer);
      } else {
        el.textContent = String(current);
      }
    }, 30);
  });
</script>
