---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export const prerender = true;

export async function getStaticPaths() {
  const events = await getCollection("events");
  return events.map((event) => ({ params: { slug: event.slug }, props: { event } }));
}

const { event } = Astro.props;
const { Content } = await event.render();
---
<BaseLayout title={event.data.title} description={event.data.description}>
  <section class="mx-auto max-w-4xl px-4 py-16">
    <p class="text-xs uppercase tracking-[0.3em] text-brand-yellow">Evenement</p>
    <h1 class="section-title mt-2 text-4xl md:text-5xl">{event.data.title}</h1>
    <p class="mt-3 text-sm text-slate-600">{event.data.date} • {event.data.time} • {event.data.location}</p>
    {event.data.image && <img src={event.data.image} alt={event.data.title} class="mt-6 aspect-[3/4] w-full rounded-3xl border border-slate-200 object-cover md:aspect-[16/10]" />}
    <div class="article-content mt-6 space-y-4 text-sm text-slate-700">
      <p>{event.data.description}</p>
      <Content />
      <p class="rounded-2xl border border-slate-200 bg-white p-4">CTA: {event.data.cta}</p>
      {event.data.map && (
        <a class="text-brand-yellow" href={event.data.map} target="_blank" rel="noopener">Voir la carte</a>
      )}
    </div>
  </section>
</BaseLayout>
