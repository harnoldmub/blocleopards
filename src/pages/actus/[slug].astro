---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ShareLinks from "../../components/ShareLinks.astro";
import { getCollection } from "astro:content";

export const prerender = true;

export async function getStaticPaths() {
  const news = await getCollection("news");
  return news.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await item.render();
const shareUrl = Astro.url?.toString() ?? "";
---
<BaseLayout title={item.data.title} description={item.data.description} image={item.data.image}>
  <article class="mx-auto max-w-4xl px-4 py-16">
    <p class="text-xs uppercase tracking-[0.3em] text-brand-yellow">Actualite</p>
    <h1 class="section-title mt-2 text-4xl md:text-5xl">{item.data.title}</h1>
    <p class="mt-3 text-sm text-slate-600">{item.data.date}</p>
    <p class="mt-5 text-lg leading-8 text-slate-700">{item.data.description}</p>
    {item.data.video ? (
      <div class="mx-auto mt-8 max-w-sm">
        <video class="aspect-[9/16] w-full rounded-3xl border border-slate-200 bg-slate-950 object-cover shadow-deep" controls poster={item.data.image}>
          <source src={item.data.video} type="video/mp4" />
        </video>
      </div>
    ) : (
      item.data.image && <img src={item.data.image} alt={item.data.title} class="mt-8 aspect-[3/4] w-full rounded-3xl border border-slate-200 object-cover shadow-deep md:aspect-[16/10]" />
    )}
    {item.data.audio && (
      <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4">
        <p class="text-xs uppercase tracking-[0.3em] text-brand-yellow">Audio</p>
        <audio class="mt-3 w-full" controls src={item.data.audio}></audio>
      </div>
    )}
    <div class="article-content mt-8 space-y-4 text-slate-700">
      <Content />
      <div class="rounded-2xl border border-slate-200 bg-white p-4 text-sm">
        <p class="text-xs uppercase tracking-[0.3em] text-brand-yellow">Tags</p>
        <p class="mt-2">{item.data.tags.join(", ")}</p>
      </div>
      {item.data.sourceUrl && (
        <a class="inline-flex rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700" href={item.data.sourceUrl} target="_blank" rel="noopener">
          Source: {item.data.sourceTitle ?? item.data.sourceUrl}
        </a>
      )}
      <ShareLinks title={item.data.title} url={shareUrl} />
    </div>
  </article>
</BaseLayout>
