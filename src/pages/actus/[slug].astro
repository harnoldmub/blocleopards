---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ShareLinks from "../../components/ShareLinks.astro";
import { requireDatabase } from "../../lib/neon";

const { slug } = Astro.params;
const sql = requireDatabase();
const [item] = await sql`SELECT * FROM articles WHERE slug = ${slug} AND published = true`;

if (!item) return Astro.redirect("/actus");

const shareUrl = Astro.url?.toString() ?? "";
---
<BaseLayout title={item.title} description={item.description} image={item.image}>
  <article class="mx-auto max-w-4xl px-4 py-16">
    <p class="text-xs uppercase tracking-[0.3em] text-brand-yellow">Actualite</p>
    <h1 class="section-title mt-2 text-4xl md:text-5xl">{item.title}</h1>
    <p class="mt-3 text-sm text-slate-600">{item.date}</p>
    <p class="mt-5 text-lg leading-8 text-slate-700">{item.description}</p>
    {item.video ? (
      <div class="mx-auto mt-8 max-w-sm">
        <video class="aspect-[9/16] w-full rounded-3xl border border-slate-200 bg-slate-950 object-cover shadow-deep" controls poster={item.image}>
          <source src={item.video} type="video/mp4" />
        </video>
      </div>
    ) : (
      item.image && <img src={item.image} alt={item.title} class="mt-8 aspect-[3/4] w-full rounded-3xl border border-slate-200 object-cover shadow-deep md:aspect-[16/10]" />
    )}
    {item.audio && (
      <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4">
        <p class="text-xs uppercase tracking-[0.3em] text-brand-yellow">Audio</p>
        <audio class="mt-3 w-full" controls src={item.audio}></audio>
      </div>
    )}
    <div class="article-content mt-8 space-y-4 text-slate-700">
      {item.body.split("\n\n").map((para: string) => (
        <p class="leading-7">{para}</p>
      ))}
      {item.tags?.length > 0 && (
        <div class="rounded-2xl border border-slate-200 bg-white p-4 text-sm">
          <p class="text-xs uppercase tracking-[0.3em] text-brand-yellow">Tags</p>
          <p class="mt-2">{item.tags.join(", ")}</p>
        </div>
      )}
      {item.source_url && (
        <a class="inline-flex rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700" href={item.source_url} target="_blank" rel="noopener">
          Source: {item.source_title ?? item.source_url}
        </a>
      )}
      <ShareLinks title={item.title} url={shareUrl} />
    </div>
  </article>
</BaseLayout>
