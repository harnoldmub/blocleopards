---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ShareLinks from "../../components/ShareLinks.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const news = await getCollection("news");
  return news.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;
const shareUrl = Astro.url?.toString() ?? "";
---
<BaseLayout title={item.data.title} description={item.data.description}>
  <section class="mx-auto max-w-4xl px-4 py-16">
    <p class="text-xs uppercase tracking-[0.3em] text-brand-yellow">DEMO</p>
    <h1 class="section-title mt-2 text-4xl md:text-5xl">{item.data.title}</h1>
    <p class="mt-3 text-sm text-slate-600">{item.data.date}</p>
    {item.data.image && <img src={item.data.image} alt={item.data.title} class="mt-6 rounded-3xl border border-slate-200" />}
    <div class="mt-6 space-y-4 text-sm text-slate-700">
      <p>{item.data.description}</p>
      <p>{item.body}</p>
      <div class="rounded-2xl border border-slate-200 bg-white p-4">
        <p class="text-xs uppercase tracking-[0.3em] text-brand-yellow">Tags</p>
        <p class="mt-2">{item.data.tags.join(", ")}</p>
      </div>
      <ShareLinks title={item.data.title} url={shareUrl} />
    </div>
  </section>
</BaseLayout>
