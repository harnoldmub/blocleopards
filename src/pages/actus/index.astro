---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import Card from "../../components/Card.astro";
import { getCollection } from "astro:content";

const news = (await getCollection("news")).sort((a, b) => {
  const byDate = b.data.date.localeCompare(a.data.date);
  return byDate || b.slug.localeCompare(a.slug);
});
---
<BaseLayout title="Actualites" description="Annonces et actualites du Bloc Leopards.">
  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeader eyebrow="Actus" title="Dernieres actualites" description="Articles, sources et mobilisation autour des Leopards de la RD Congo." />
    <div class="grid gap-6 md:grid-cols-3">
      {news.map((item) => (
        <Card
          title={item.data.title}
          description={item.data.description}
          meta={item.data.date}
          image={item.data.image}
          href={`/actus/${item.slug}`}
          cta="Lire"
        />
      ))}
    </div>
  </section>
</BaseLayout>
