---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import Card from "../../components/Card.astro";
import { requireDatabase } from "../../lib/neon";

const sql = requireDatabase();
const news = await sql`SELECT * FROM articles WHERE published = true ORDER BY date DESC, created_at DESC`;
---
<BaseLayout title="Actualites" description="Annonces et actualites du Bloc Leopards.">
  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeader eyebrow="Actus" title="Dernieres actualites" description="Articles, sources et mobilisation autour des Leopards de la RD Congo." />
    <div class="grid gap-6 md:grid-cols-3">
      {news.map((item) => (
        <Card
          title={item.title}
          description={item.description}
          meta={item.date}
          image={item.image}
          href={`/actus/${item.slug}`}
          cta="Lire"
        />
      ))}
    </div>
  </section>
</BaseLayout>
