---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import kit from "../data/kit.json";
import { getCollection } from "astro:content";

const today = new Date().toISOString().slice(0, 10);
const matches = (await getCollection("matches"))
  .sort((a, b) => a.data.date.localeCompare(b.data.date))
  .filter((match) => match.data.date >= today);
---
<BaseLayout title="Matchs" description="Calendrier des matchs et mobilisation.">
  <PageHero title="Matchs" subtitle="Preparation des Leopards" image="/media/hommage-diaspora-cover.jpg" />
  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeader eyebrow="Calendrier reel" title="Matchs amicaux confirmes" description="Deux tests de preparation avant le Mondial 2026, selon Digital Congo." />
    <div class="grid gap-6 md:grid-cols-2">
      {matches.map((match) => (
        <article class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-deep">
          <img
            src={match.data.opponent === "Danemark" ? "/media/hommage-diaspora-cover.jpg" : "/media/supporters-diaspora-06.jpg"}
            alt={`RDC vs ${match.data.opponent}`}
            class="aspect-[3/4] w-full object-cover md:aspect-[16/10]"
          />
          <div class="p-6">
          <p class="text-xs uppercase tracking-[0.3em] text-brand-yellow">{match.data.date} • {match.data.time}</p>
          <h3 class="mt-2 text-2xl font-semibold">RDC vs {match.data.opponent}</h3>
          <p class="mt-2 text-sm text-slate-600">Lieu: {match.data.location}</p>
          <p class="mt-4 text-sm">{match.data.callToAction}</p>
          <a class="mt-5 inline-flex rounded-full border border-slate-300 px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-slate-700" href="https://digitalcongo.org/detail15035-mondial-2026-les-leopards-s-offrent-le-danemark-et-le-chili-en-amical" target="_blank" rel="noopener">Source</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <SectionHeader eyebrow="Kit chants" title="Chants officiels" description="Selection de chants positifs, sans insultes." />
      <div class="grid gap-4 md:grid-cols-2">
        {kit.chants.map((chant) => (
          <div class="rounded-2xl border border-slate-200 bg-white p-4 text-sm">{chant}</div>
        ))}
      </div>
      <a href="/downloads/kit-supporters.pdf" class="mt-6 inline-flex rounded-full bg-brand-yellow px-6 py-3 text-sm font-semibold text-brand-dark">Telecharger le kit supporters</a>
    </div>
  </section>
</BaseLayout>
