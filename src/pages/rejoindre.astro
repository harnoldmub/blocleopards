---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import faq from "../data/faq.json";
import CountryCitySelect from "../components/CountryCitySelect.tsx";

const roles = [
  "Ambiance / chants",
  "Photo & video",
  "Organisation fan zone",
  "Relais diaspora",
  "Moderation digitale",
  "Partenariat local"
];

const canals = ["WhatsApp", "Email", "Telephone", "Instagram"];

const disponibilites = [
  "Matchs uniquement",
  "Quelques heures par mois",
  "Chaque semaine",
  "Disponible pour organiser"
];
---
<BaseLayout title="Rejoindre" description="Formulaire d'adhesion Bloc Leopards.">
  <PageHero title="Rejoindre" subtitle="Engage-toi pour un support positif" image="/media/atelier-1.svg" />
  <section class="mx-auto max-w-5xl px-4 py-16">

    {Astro.url.searchParams.get("status") === "success" && (
      <div class="mb-6 rounded-2xl border border-emerald-200 bg-emerald-50 p-4 text-sm text-emerald-800">
        Adhesion recue. Bienvenue dans le Bloc.
      </div>
    )}
    {Astro.url.searchParams.get("status") === "error" && (
      <div class="mb-6 rounded-2xl border border-red-200 bg-red-50 p-4 text-sm text-red-800">
        Impossible d'enregistrer l'adhesion pour le moment. Verifie la connexion Neon.
      </div>
    )}

    <div class="grid gap-8 lg:grid-cols-[1fr_0.72fr]">
      <form name="adhesion" method="POST" action="/api/adhesion" class="grid gap-6 rounded-3xl border border-slate-200 bg-white p-6 text-sm shadow-deep">
        <input name="_hp" type="text" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;height:0;width:0;" />
        <input name="_t" type="hidden" id="adhesion-t" />
        <script>document.getElementById('adhesion-t').value = Date.now();</script>
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.28em] text-brand-yellow">Adhesion</p>
          <h2 class="mt-2 text-2xl font-semibold text-slate-950">Dis-nous comment tu veux aider</h2>
          <p class="mt-2 text-sm leading-6 text-slate-600">Le formulaire alimente la base membres pour organiser les chants, les fan zones, les relais diaspora et les equipes media.</p>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          <label class="grid gap-2">
            <span class="font-semibold text-slate-700">Prenom *</span>
            <input name="prenom" placeholder="Ex: Sarah" required autocomplete="given-name" class="rounded-xl border border-slate-300 bg-white px-4 py-3 outline-none transition focus:border-brand-yellow focus:ring-4 focus:ring-brand-yellow/20" />
          </label>
          <label class="grid gap-2">
            <span class="font-semibold text-slate-700">Nom *</span>
            <input name="nom" placeholder="Ex: Kalala" required autocomplete="family-name" class="rounded-xl border border-slate-300 bg-white px-4 py-3 outline-none transition focus:border-brand-yellow focus:ring-4 focus:ring-brand-yellow/20" />
          </label>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          <label class="grid gap-2">
            <span class="font-semibold text-slate-700">Email *</span>
            <input type="email" name="email" placeholder="nom@email.com" required autocomplete="email" class="rounded-xl border border-slate-300 bg-white px-4 py-3 outline-none transition focus:border-brand-yellow focus:ring-4 focus:ring-brand-yellow/20" />
          </label>
          <label class="grid gap-2">
            <span class="font-semibold text-slate-700">Telephone</span>
            <input type="tel" name="telephone" placeholder="+243..." autocomplete="tel" class="rounded-xl border border-slate-300 bg-white px-4 py-3 outline-none transition focus:border-brand-yellow focus:ring-4 focus:ring-brand-yellow/20" />
          </label>
        </div>

        <CountryCitySelect client:load />

        <div class="grid gap-4 md:grid-cols-2">
          <label class="grid gap-2">
            <span class="font-semibold text-slate-700">Role souhaite *</span>
            <select name="role" required class="rounded-xl border border-slate-300 bg-white px-4 py-3 outline-none transition focus:border-brand-yellow focus:ring-4 focus:ring-brand-yellow/20">
              <option value="">Choisir un role</option>
              {roles.map((role) => <option value={role}>{role}</option>)}
            </select>
          </label>
          <label class="grid gap-2">
            <span class="font-semibold text-slate-700">Canal prefere</span>
            <select name="canal" class="rounded-xl border border-slate-300 bg-white px-4 py-3 outline-none transition focus:border-brand-yellow focus:ring-4 focus:ring-brand-yellow/20">
              <option value="">Choisir</option>
              {canals.map((canal) => <option value={canal}>{canal}</option>)}
            </select>
          </label>
        </div>

        <fieldset class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
          <legend class="px-2 text-sm font-semibold text-slate-800">Disponibilite</legend>
          <div class="mt-3 grid gap-3 sm:grid-cols-2">
            {disponibilites.map((item) => (
              <label class="flex items-center gap-3 rounded-xl border border-slate-200 bg-white p-3 text-sm text-slate-700">
                <input type="radio" name="disponibilite" value={item} class="h-4 w-4 accent-brand-yellow" />
                {item}
              </label>
            ))}
          </div>
        </fieldset>

        <label class="grid gap-2">
          <span class="font-semibold text-slate-700">Motivation</span>
          <textarea name="motivation" placeholder="Ta ville, ton groupe, une idee d'action, une competence..." rows="5" class="rounded-xl border border-slate-300 bg-white px-4 py-3 outline-none transition focus:border-brand-yellow focus:ring-4 focus:ring-brand-yellow/20"></textarea>
        </label>

        <div class="grid gap-3 rounded-2xl border border-slate-200 bg-slate-50 p-4">
          <label class="flex items-start gap-3 text-sm text-slate-700">
            <input type="checkbox" name="charte" required class="mt-1 h-4 w-4 accent-brand-yellow" />
            <span>J'ai lu et j'accepte la <a href="/charte" class="font-semibold text-brand-yellow">Charte du Supporter</a>. *</span>
          </label>
          <label class="flex items-start gap-3 text-sm text-slate-700">
            <input type="checkbox" name="newsletter" class="mt-1 h-4 w-4 accent-brand-yellow" />
            <span>Je veux recevoir les mobilisations confirmees, fan zones et infos du Bloc.</span>
          </label>
        </div>

        <button type="submit" class="rounded-full bg-brand-yellow px-6 py-4 text-sm font-semibold text-brand-dark transition hover:bg-brand-dark hover:text-white">Envoyer ma demande</button>
      </form>

      <aside class="grid content-start gap-5">
        <div class="rounded-3xl border border-slate-200 bg-brand-blue p-6 text-white shadow-deep">
          <p class="text-xs font-semibold uppercase tracking-[0.28em] text-brand-yellow">Parcours</p>
          <h3 class="mt-3 text-2xl font-semibold">Apres l'inscription</h3>
          <ol class="mt-5 grid gap-4 text-sm text-slate-100">
            <li><span class="font-semibold text-brand-yellow">1.</span> On verifie ta ville et ton role.</li>
            <li><span class="font-semibold text-brand-yellow">2.</span> Tu recois les infos utiles selon ton canal prefere.</li>
            <li><span class="font-semibold text-brand-yellow">3.</span> Tu participes aux actions confirmees du Bloc.</li>
          </ol>
        </div>
        <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 text-sm text-slate-700">
          <h3 class="text-lg font-semibold text-slate-950">Roles recherches</h3>
          <div class="mt-4 flex flex-wrap gap-2">
            {roles.map((role) => (
              <span class="rounded-full border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-700">{role}</span>
            ))}
          </div>
        </div>
      </aside>
    </div>

    <div class="mt-10 rounded-3xl border border-slate-200 bg-slate-50 p-6 text-sm">
      <h3 class="text-lg font-semibold">Regles principales</h3>
      <ul class="mt-3 list-disc pl-4 text-slate-600">
        <li>Respect des joueurs, adversaires, arbitres.</li>
        <li>Zero violence et zero messages haineux.</li>
        <li>Chants coordonnes et discipline en tribune.</li>
        <li>Engagement digital responsable.</li>
      </ul>
      <a href="/charte" class="mt-4 inline-flex text-brand-yellow">Lire la charte complete</a>
    </div>

    <div class="mt-10">
      <h3 class="text-lg font-semibold">FAQ</h3>
      <div class="mt-4 grid gap-4 md:grid-cols-2">
        {faq.map((item) => (
          <div class="rounded-2xl border border-slate-200 bg-white p-4 text-sm">
            <p class="font-semibold">{item.q}</p>
            <p class="mt-2 text-slate-600">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
