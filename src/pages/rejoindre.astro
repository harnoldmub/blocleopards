---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import faq from "../data/faq.json";
---
<BaseLayout title="Rejoindre" description="Formulaire d'adhesion Bloc Leopards.">
  <PageHero title="Rejoindre" subtitle="Engage-toi pour un support positif" image="/media/atelier-1.svg" />
  <section class="mx-auto max-w-5xl px-4 py-16">

    <form name="adhesion" method="POST" data-netlify="true" class="grid gap-4 rounded-3xl border border-slate-200 bg-white p-6 text-sm">
      <input type="hidden" name="form-name" value="adhesion" />
      <div class="grid gap-3 md:grid-cols-2">
        <input name="prenom" placeholder="Prenom" required class="rounded-xl border border-slate-300 bg-white px-4 py-3" />
        <input name="nom" placeholder="Nom" required class="rounded-xl border border-slate-300 bg-white px-4 py-3" />
      </div>
      <div class="grid gap-3 md:grid-cols-2">
        <input type="email" name="email" placeholder="Email" required class="rounded-xl border border-slate-300 bg-white px-4 py-3" />
        <input name="ville" placeholder="Ville" required class="rounded-xl border border-slate-300 bg-white px-4 py-3" />
      </div>
      <textarea name="motivation" placeholder="Pourquoi rejoindre le Bloc ?" rows="4" class="rounded-xl border border-slate-300 bg-white px-4 py-3"></textarea>
      <label class="flex items-start gap-2 text-xs text-slate-600">
        <input type="checkbox" name="charte" required class="mt-1" />
        J'ai lu et j'accepte la Charte Officielle du Supporter.
      </label>
      <button type="submit" class="mt-2 rounded-full bg-brand-yellow px-6 py-3 text-sm font-semibold text-brand-dark">Envoyer</button>
    </form>

    <div class="mt-10 rounded-3xl border border-slate-200 bg-slate-50 p-6 text-sm">
      <h3 class="text-lg font-semibold">Regles principales</h3>
      <ul class="mt-3 list-disc pl-4 text-slate-600">
        <li>Respect des joueurs, adversaires, arbitres.</li>
        <li>Zero violence et zero messages haineux.</li>
        <li>Chants unifies et discipline en tribune.</li>
        <li>Engagement digital responsable.</li>
      </ul>
      <a href="/charte" class="mt-4 inline-flex text-brand-yellow">Lire la charte complete</a>
    </div>

    <div class="mt-10">
      <h3 class="text-lg font-semibold">FAQ</h3>
      <div class="mt-4 grid gap-4 md:grid-cols-2">
        {faq.map((item) => (
          <div class="rounded-2xl border border-slate-200 bg-white p-4 text-sm">
            <p class="font-semibold">{item.q}</p>
            <p class="mt-2 text-slate-600">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
