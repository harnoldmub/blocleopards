---
import AdminLayout from "../../layouts/AdminLayout.astro";
import AdminAdhesionsDashboard from "../../components/AdminAdhesionsDashboard.tsx";
import { isAdminAuthed, hasPermission } from "../../lib/auth";

if (!isAdminAuthed(Astro.cookies)) return Astro.redirect("/admin/login");
if (!hasPermission(Astro.cookies, "adhesions")) return Astro.redirect("/admin/dashboard");
---
<AdminLayout title="Adhésions — Admin Bloc Léopards" section="adhesions">
  <AdminAdhesionsDashboard client:load />
</AdminLayout>
