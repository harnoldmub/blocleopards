---
import AdminLayout from "../../layouts/AdminLayout.astro";
import AdminNewsletterDashboard from "../../components/AdminNewsletterDashboard.tsx";
import { isAdminAuthed, hasPermission } from "../../lib/auth";

if (!isAdminAuthed(Astro.cookies)) return Astro.redirect("/admin/login");
if (!hasPermission(Astro.cookies, "newsletter")) return Astro.redirect("/admin/dashboard");
---
<AdminLayout title="Newsletter — Admin Bloc Léopards" section="newsletter">
  <AdminNewsletterDashboard client:load />
</AdminLayout>
