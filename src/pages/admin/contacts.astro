---
import AdminLayout from "../../layouts/AdminLayout.astro";
import AdminContactsDashboard from "../../components/AdminContactsDashboard.tsx";
import { isAdminAuthed, hasPermission } from "../../lib/auth";

if (!isAdminAuthed(Astro.cookies)) return Astro.redirect("/admin/login");
if (!hasPermission(Astro.cookies, "contacts")) return Astro.redirect("/admin/dashboard");
---
<AdminLayout title="Messages — Admin Bloc Léopards" section="contacts">
  <AdminContactsDashboard client:load />
</AdminLayout>
