---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { isAdminAuthed, isSuperAdmin } from "../../lib/auth";
import { requireDatabase } from "../../lib/neon";

if (!isAdminAuthed(Astro.cookies)) return Astro.redirect("/admin/login");
if (!isSuperAdmin(Astro.cookies)) return Astro.redirect("/admin/dashboard");

const sql = requireDatabase();

const logs = await sql`
  select id, admin_user, action, target_type, target_id, details, ip_address, created_at
  from admin_audit_logs
  order by created_at desc
  limit 200
`;

const users = await sql`select distinct admin_user from admin_audit_logs order by admin_user`;
const actions = await sql`select distinct action from admin_audit_logs order by action`;

const ACTION_LABELS: Record<string, { label: string; color: string }> = {
  login:                  { label: "Connexion",          color: "#22c55e" },
  login_failed:           { label: "Échec connexion",    color: "#ef4444" },
  logout:                 { label: "Déconnexion",        color: "#94a3b8" },
  verify_inscription:     { label: "Inscription validée",color: "#22c55e" },
  reject_inscription:     { label: "Inscription rejetée",color: "#f97316" },
  verify_group:           { label: "Validation groupe",  color: "#22c55e" },
  reject_group:           { label: "Rejet groupe",       color: "#f97316" },
  delete_inscription:     { label: "Inscription supprimée", color: "#ef4444" },
  delete_documents_rgpd:  { label: "Docs RGPD supprimés",color: "#a78bfa" },
  run_draw:               { label: "Tirage lancé",       color: "#f7d618" },
  publish_draw:           { label: "Tirage publié",      color: "#007fff" },
  create_role:            { label: "Rôle créé",          color: "#22c55e" },
  update_role:            { label: "Rôle modifié",       color: "#f7d618" },
  delete_role:            { label: "Rôle supprimé",      color: "#ef4444" },
};

function formatDate(d: string) {
  return new Date(d).toLocaleString("fr-FR", { day: "2-digit", month: "short", year: "numeric", hour: "2-digit", minute: "2-digit", second: "2-digit" });
}
---
<AdminLayout title="Logs — Admin Bloc Léopards" section="logs">
  <div style="max-width:1100px;">
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:28px; flex-wrap:wrap; gap:12px;">
      <div>
        <p style="font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:rgba(255,255,255,0.4); font-weight:700; margin-bottom:6px;">Supervision</p>
        <h1 style="font-size:1.75rem; font-weight:800; color:#fff;">Historique des actions</h1>
      </div>
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <select id="filter-user" style="padding:8px 12px; background:#0d1117; border:1px solid rgba(255,255,255,0.12); border-radius:8px; color:#fff; font-size:13px; outline:none;">
          <option value="">Tous les utilisateurs</option>
          {users.map((u: any) => <option value={u.admin_user}>{u.admin_user}</option>)}
        </select>
        <select id="filter-action" style="padding:8px 12px; background:#0d1117; border:1px solid rgba(255,255,255,0.12); border-radius:8px; color:#fff; font-size:13px; outline:none;">
          <option value="">Toutes les actions</option>
          {actions.map((a: any) => {
            const meta = ACTION_LABELS[a.action];
            return <option value={a.action}>{meta ? meta.label : a.action}</option>;
          })}
        </select>
      </div>
    </div>

    <div style="background:#0d1117; border:1px solid rgba(255,255,255,0.07); border-radius:16px; overflow:hidden;">
      <table style="width:100%; border-collapse:collapse; font-size:13px;">
        <thead>
          <tr style="border-bottom:1px solid rgba(255,255,255,0.07);">
            <th style="padding:14px 16px; text-align:left; font-size:10px; text-transform:uppercase; letter-spacing:0.14em; color:rgba(255,255,255,0.35); font-weight:700;">Date</th>
            <th style="padding:14px 16px; text-align:left; font-size:10px; text-transform:uppercase; letter-spacing:0.14em; color:rgba(255,255,255,0.35); font-weight:700;">Utilisateur</th>
            <th style="padding:14px 16px; text-align:left; font-size:10px; text-transform:uppercase; letter-spacing:0.14em; color:rgba(255,255,255,0.35); font-weight:700;">Action</th>
            <th style="padding:14px 16px; text-align:left; font-size:10px; text-transform:uppercase; letter-spacing:0.14em; color:rgba(255,255,255,0.35); font-weight:700;">Détails</th>
            <th style="padding:14px 16px; text-align:left; font-size:10px; text-transform:uppercase; letter-spacing:0.14em; color:rgba(255,255,255,0.35); font-weight:700;">IP</th>
          </tr>
        </thead>
        <tbody id="logs-body">
          {logs.length === 0 && (
            <tr>
              <td colspan="5" style="padding:48px; text-align:center; color:rgba(255,255,255,0.25); font-size:14px;">Aucune action enregistrée.</td>
            </tr>
          )}
          {logs.map((log: any) => {
            const meta = ACTION_LABELS[log.action] ?? { label: log.action, color: "#94a3b8" };
            const details = typeof log.details === "object" && log.details !== null ? log.details : {};
            const detailStr = Object.entries(details).map(([k, v]) => `${k}: ${v}`).join(" · ");
            return (
              <tr class="log-row" data-user={log.admin_user} data-action={log.action} style="border-bottom:1px solid rgba(255,255,255,0.04);">
                <td style="padding:12px 16px; color:rgba(255,255,255,0.45); font-size:12px; white-space:nowrap; font-family:monospace;">{formatDate(log.created_at)}</td>
                <td style="padding:12px 16px;">
                  <span style={`display:inline-block; padding:2px 8px; border-radius:20px; font-size:11px; font-weight:700; background:rgba(247,214,24,0.1); color:#f7d618; border:1px solid rgba(247,214,24,0.2);`}>
                    {log.admin_user}
                  </span>
                </td>
                <td style="padding:12px 16px;">
                  <span style={`display:inline-block; padding:3px 9px; border-radius:6px; font-size:11px; font-weight:700; background:${meta.color}18; color:${meta.color};`}>
                    {meta.label}
                  </span>
                </td>
                <td style="padding:12px 16px; color:rgba(255,255,255,0.5); font-size:12px; max-width:320px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title={detailStr}>
                  {log.target_id && <span style="color:rgba(255,255,255,0.3); margin-right:6px;">#{log.target_id}</span>}
                  {detailStr}
                </td>
                <td style="padding:12px 16px; color:rgba(255,255,255,0.25); font-size:11px; font-family:monospace;">{log.ip_address ?? "—"}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>

<script>
  const filterUser = document.getElementById('filter-user') as HTMLSelectElement;
  const filterAction = document.getElementById('filter-action') as HTMLSelectElement;

  function applyFilters() {
    const user = filterUser.value;
    const action = filterAction.value;
    document.querySelectorAll<HTMLTableRowElement>('.log-row').forEach(row => {
      const matchUser = !user || row.dataset.user === user;
      const matchAction = !action || row.dataset.action === action;
      row.style.display = matchUser && matchAction ? '' : 'none';
    });
  }

  filterUser.addEventListener('change', applyFilters);
  filterAction.addEventListener('change', applyFilters);
</script>
