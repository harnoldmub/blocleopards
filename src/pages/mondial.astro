---
import BaseLayout from "../layouts/BaseLayout.astro";
import { requireDatabase, hasDatabase } from "../lib/neon";

// Fetch actual supporters who opted in
let dbSupporters: any[] = [];
if (hasDatabase) {
  try {
    const sql = requireDatabase();
    dbSupporters = await sql`
      select first_name, city, state_us, country
      from mondial_inscriptions
      where opt_in_mur = true and verification_status = 'verified'
      order by created_at desc
      limit 40
    `;
  } catch (err) {
    console.error("Error fetching supporters for wall:", err);
  }
}

const mockSupporters = [
  { first_name: "Arnold", city: "Houston", state_us: "TX", country: "USA" },
  { first_name: "Merveille", city: "Atlanta", state_us: "GA", country: "USA" },
  { first_name: "Béni", city: "Dallas", state_us: "TX", country: "USA" },
  { first_name: "Jonathan", city: "New York", state_us: "NY", country: "USA" },
  { first_name: "Sarah", city: "Washington", state_us: "DC", country: "USA" },
  { first_name: "Grace", city: "Los Angeles", state_us: "CA", country: "USA" },
  { first_name: "Dieudonné", city: "Chicago", state_us: "IL", country: "USA" },
  { first_name: "Rachel", city: "Miami", state_us: "FL", country: "USA" },
  { first_name: "Christian", city: "Seattle", state_us: "WA", country: "USA" },
];

const supporters = [...dbSupporters, ...mockSupporters];

const matches = [
  {
    id: "match-1",
    key: "rdc-portugal",
    home: "RDC",
    away: "PORTUGAL",
    awayFlag: "pt",
    venue: "NRG Stadium",
    city: "Houston, USA",
    dateStr: "17 Juin 2026",
    utcKickoff: "2026-06-17T17:00:00Z",
    color: "from-blue-600/20 to-yellow-500/10",
    glow: "rgba(247,214,24,0.15)",
    warning: null
  },
  {
    id: "match-3",
    key: "rdc-uzbekistan",
    home: "RDC",
    away: "OUZBÉKISTAN",
    awayFlag: "uz",
    venue: "Mercedes-Benz Stadium",
    city: "Atlanta, USA",
    dateStr: "27 Juin 2026",
    utcKickoff: "2026-06-27T23:30:00Z",
    color: "from-emerald-600/20 to-blue-500/10",
    glow: "rgba(0,127,255,0.15)",
    warning: null
  }
];
---
<BaseLayout title="Mondial 2026 — Expérience USA" description="Poussez les Léopards de la RDC vers la gloire en Amérique du Nord. Inscriptions au tirage au sort des billets.">
  <div class="relative overflow-hidden bg-[#07090f] text-white font-sans">

    <!-- Hero avec photo de fond -->
    <div class="relative min-h-[90vh] flex items-center">
      <!-- Background photo -->
      <div class="absolute inset-0 overflow-hidden">
        <img
          src="/media/ivanor-foule-tribune.jpg"
          alt="Supporters RDC"
          class="w-full h-full object-cover object-center"
          style="opacity:0.35;"
        />
        <div class="absolute inset-0" style="background:linear-gradient(to bottom, rgba(7,9,15,0.5) 0%, rgba(7,9,15,0.2) 40%, rgba(7,9,15,0.85) 100%);"></div>
      </div>

      <div class="relative z-10 w-full max-w-6xl mx-auto px-4 pb-28 pt-12 text-center md:pb-36 md:pt-8 lg:pb-44 lg:pt-4">
        <div class="mx-auto max-w-4xl">
          <div class="mb-8 flex items-center justify-center gap-5">
            <img src="/brand/logo.png" alt="Bloc Léopards" class="h-12 w-auto drop-shadow-[0_0_16px_rgba(247,214,24,0.4)]" />
            <div class="h-8 w-px bg-white/25"></div>
            <p class="text-xs uppercase tracking-[0.45em] text-[#f7d618] font-bold">Coupe du Monde 2026</p>
          </div>
          <h1 class="font-bebas text-6xl md:text-8xl tracking-wide leading-none text-white mb-8">
            L'EXPÉRIENCE <span class="text-[#f7d618]">USA</span>
          </h1>
          <p class="mx-auto text-slate-300 text-base md:text-lg max-w-2xl leading-relaxed mb-10">
            Pour le retour historique des Léopards de la RDC sur la scène mondiale après 52 ans, participez au tirage au sort vérifiable des billets pour les 3 matchs de poule.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <a href="/mondial/tirage" class="px-7 py-3.5 rounded-full bg-[#f7d618] text-[#07090f] font-bold text-sm hover:bg-yellow-400 transition-all shadow-[0_4px_24px_rgba(247,214,24,0.4)]">
              Participer au Tirage
            </a>
            <a href="/mondial/transparence" class="px-7 py-3.5 rounded-full border border-white/25 backdrop-blur-sm hover:bg-white/10 transition-all text-sm font-semibold">
              Transparence & Algorithme
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="relative z-20 -mt-28 px-4 pb-16 md:-mt-40 lg:-mt-48">
    <div class="max-w-6xl mx-auto relative z-10">

      <!-- Match cards grid -->
      <div class="grid gap-8 md:grid-cols-3 mb-20">
        {matches.map((match) => (
          <div 
            class={`relative overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-b ${match.color} p-6 flex flex-col justify-between`}
            style={{ boxShadow: `0 10px 30px -10px ${match.glow}` }}
          >
            <!-- Header info -->
            <div class="mb-6 flex justify-between items-start">
              <div>
                <span class="text-[10px] tracking-[0.15em] uppercase text-slate-400 font-bold">Phase de Groupes</span>
                <h3 class="font-bebas text-2xl text-white tracking-wide mt-1">{match.venue}</h3>
                <p class="text-xs text-slate-400">{match.city}</p>
              </div>
              <div class="px-2.5 py-1 bg-white/5 rounded-full text-[10px] uppercase font-bold text-[#f7d618] border border-[#f7d618]/20">
                Mondial 2026
              </div>
            </div>

            <!-- Scoreboard display -->
            <div class="flex items-center justify-between gap-4 py-4 mb-4 border-y border-white/5 bg-black/20 rounded-2xl px-4">
              <div class="flex flex-col items-center flex-1">
                <img src="/flags/cd.png" alt="RDC" class="h-10 w-auto rounded shadow-md object-cover" />
                <span class="font-bebas text-lg text-white mt-1">RDC</span>
              </div>
              <span class="font-bebas text-2xl text-slate-500 font-bold">VS</span>
              <div class="flex flex-col items-center flex-1">
                <img src={`/flags/${match.awayFlag}.png`} alt={match.away} class="h-10 w-auto rounded shadow-md object-cover" />
                <span class="font-bebas text-lg text-white mt-1">{match.away}</span>
              </div>
            </div>

            <!-- Warning or Notice -->
            {match.warning && (
              <div class="mb-4 p-3 rounded-xl bg-red-950/40 border border-red-500/20 text-[11px] text-red-300 leading-normal flex gap-2">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:1px" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                <span>{match.warning}</span>
              </div>
            )}

            <!-- Date & Countdown -->
            <div class="mt-4 pt-4 border-t border-white/5">
              <div class="flex justify-between items-center text-xs text-slate-400 mb-2">
                <span>Date officielle (UTC)</span>
                <span>{match.dateStr}</span>
              </div>
              
              <!-- Local time slot -->
              <div class="text-xs font-semibold text-[#f7d618] mb-3 bg-[#f7d618]/10 py-1.5 px-3 rounded-lg border border-[#f7d618]/20 flex justify-between items-center">
                <span>Heure locale chez vous :</span>
                <span class="local-time" data-utc={match.utcKickoff}>Chargement...</span>
              </div>

              <!-- Countdown timer -->
              <div class="grid grid-cols-4 gap-1 text-center bg-black/40 rounded-xl p-2.5" data-countdown={match.utcKickoff}>
                <div>
                  <div class="font-bebas text-xl text-white days">00</div>
                  <div class="text-[9px] uppercase text-slate-500">Jours</div>
                </div>
                <div>
                  <div class="font-bebas text-xl text-white hours">00</div>
                  <div class="text-[9px] uppercase text-slate-500">Heures</div>
                </div>
                <div>
                  <div class="font-bebas text-xl text-white minutes">00</div>
                  <div class="text-[9px] uppercase text-slate-500">Min</div>
                </div>
                <div>
                  <div class="font-bebas text-xl text-[#f7d618] seconds">00</div>
                  <div class="text-[9px] uppercase text-slate-500">Sec</div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Supporters Wall Marquee -->
      <div class="mb-20 bg-white/5 border border-white/10 rounded-3xl p-8 relative overflow-hidden">
        <div class="absolute inset-0 bg-radial-at-t from-[#f7d618]/5 to-transparent pointer-events-none"></div>
        <div class="text-center max-w-xl mx-auto mb-6">
          <span class="text-xs uppercase tracking-[0.2em] text-[#f7d618] font-bold">Le Mur des Supporters</span>
          <h2 class="font-bebas text-3xl text-white mt-2">ILS SERONT DANS LE BLOC AUX USA</h2>
          <p class="text-slate-400 text-xs mt-1">Rejoignez la diaspora et affichez votre soutien en participant au tirage.</p>
        </div>

        <!-- Marquee container -->
        <div class="supporters-marquee-wrapper relative flex overflow-x-hidden border-y border-white/5 py-4 select-none">
          <div class="supporters-marquee flex gap-8 whitespace-nowrap animate-marquee">
            {supporters.map((s) => (
              <div class="flex items-center gap-2 bg-white/5 px-4 py-2 rounded-full border border-white/5 text-sm">
                <span class="font-semibold text-white">{s.first_name}</span>
                <span class="text-slate-400">({s.city}, {s.state_us})</span>
                <img src="/flags/us.png" alt="USA" class="h-4 w-auto rounded" />
              </div>
            ))}
          </div>
          <!-- Second clone for infinite loop -->
          <div class="supporters-marquee flex gap-8 whitespace-nowrap animate-marquee" aria-hidden="true">
            {supporters.map((s) => (
              <div class="flex items-center gap-2 bg-white/5 px-4 py-2 rounded-full border border-white/5 text-sm">
                <span class="font-semibold text-white">{s.first_name}</span>
                <span class="text-slate-400">({s.city}, {s.state_us})</span>
                <img src="/flags/us.png" alt="USA" class="h-4 w-auto rounded" />
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Important Notice / RGPD / Transport -->
      <div class="grid md:grid-cols-2 gap-8 text-sm text-slate-400 border-t border-white/10 pt-10">
        <div>
          <h4 class="font-bold text-white mb-2"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.8 19.2L16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg> Logistique & Logement à votre charge</h4>
          <p class="leading-relaxed">
            Le Bloc Léopards organise et garantit un tirage au sort transparent des billets d'accès en tribune pour soutenir la RDC. Le transport (vols, visas, déplacements) et l'hébergement restent à la charge entière du supporter.
          </p>
        </div>
        <div>
          <h4 class="font-bold text-white mb-2"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="3" x2="12" y2="21"/><path d="M5 6l7-3 7 3M3 18h18"/><path d="M3 18l3-9 9 3-3 9M21 18l-3-9-9 3 3 9"/></svg> Mentions Légales & Institutionnelles</h4>
          <p class="leading-relaxed">
            En co-branding avec le Ministère des Sports. Les annonces institutionnelles restent à vérifier auprès des organismes compétents. Les documents d'identité collectés sont chiffrés et seront supprimés après la réalisation du tirage au sort.
          </p>
        </div>
      </div>
    </div>
    </div>
  </div>
</BaseLayout>

<style>
  .font-bebas {
    font-family: 'Bebas Neue', sans-serif;
  }
  
  /* Marquee keyframes */
  @keyframes marquee {
    0% { transform: translateX(0%); }
    100% { transform: translateX(-100%); }
  }
  .animate-marquee {
    animation: marquee 25s linear infinite;
  }
  .supporters-marquee-wrapper:hover .supporters-marquee {
    animation-play-state: paused;
  }
</style>

<script>
  // Format local times
  document.querySelectorAll('.local-time').forEach((el) => {
    const utcStr = el.getAttribute('data-utc');
    if (utcStr) {
      const date = new Date(utcStr);
      // Format to user's locale
      const options: Intl.DateTimeFormatOptions = { 
        weekday: 'short', 
        day: 'numeric', 
        month: 'short', 
        hour: '2-digit', 
        minute: '2-digit' 
      };
      el.textContent = date.toLocaleDateString(navigator.language, options);
    }
  });

  // Countdown timers
  document.querySelectorAll('[data-countdown]').forEach((el) => {
    const utcStr = el.getAttribute('data-countdown');
    if (!utcStr) return;
    const targetDate = new Date(utcStr).getTime();

    const daysEl = el.querySelector('.days');
    const hoursEl = el.querySelector('.hours');
    const minsEl = el.querySelector('.minutes');
    const secsEl = el.querySelector('.seconds');

    function update() {
      const now = new Date().getTime();
      const diff = targetDate - now;

      if (diff <= 0) {
        if (daysEl) daysEl.textContent = '00';
        if (hoursEl) hoursEl.textContent = '00';
        if (minsEl) minsEl.textContent = '00';
        if (secsEl) secsEl.textContent = '00';
        return;
      }

      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((diff % (1000 * 60)) / 1000);

      if (daysEl) daysEl.textContent = String(days).padStart(2, '0');
      if (hoursEl) hoursEl.textContent = String(hours).padStart(2, '0');
      if (minsEl) minsEl.textContent = String(minutes).padStart(2, '0');
      if (secsEl) secsEl.textContent = String(seconds).padStart(2, '0');
    }

    update();
    setInterval(update, 1000);
  });
</script>
