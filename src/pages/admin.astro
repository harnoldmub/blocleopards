---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
---
<BaseLayout title="Admin" description="Backoffice minimal Bloc Leopards.">
  <section class="mx-auto max-w-4xl px-4 py-16">
    <SectionHeader eyebrow="Admin" title="Backoffice Sanity" description="Sanity est branche pour gerer le contenu editorial du site." />
    <div class="grid gap-4 text-sm text-slate-600">
      <div class="rounded-3xl border border-slate-200 bg-white p-6">
        <p>Le backoffice est pret pour les collections principales: actualites, evenements, matchs, campagnes, galerie et parametres du site.</p>
        <div class="mt-5 flex flex-wrap gap-3">
          <a class="rounded-full bg-brand-yellow px-5 py-3 text-sm font-semibold text-brand-dark" href="http://127.0.0.1:3333/studio" target="_blank" rel="noopener">Ouvrir le Studio local</a>
          <a class="rounded-full border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700" href="https://www.sanity.io/manage" target="_blank" rel="noopener">Sanity Manage</a>
        </div>
      </div>
      <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6">
        <p class="font-semibold text-slate-900">Configuration requise</p>
        <ul class="mt-3 list-disc pl-4">
          <li>Creer un projet Sanity et recuperer le project ID.</li>
          <li>Renseigner <code>PUBLIC_SANITY_PROJECT_ID</code> et <code>SANITY_STUDIO_PROJECT_ID</code>.</li>
          <li>Lancer <code>npm run cms:dev</code> pour travailler dans le Studio local.</li>
          <li>Le site garde les fichiers Markdown/JSON comme fallback tant que les donnees Sanity ne sont pas publiees.</li>
      </ul>
      </div>
    </div>
  </section>
</BaseLayout>
